      {%- comment -%} Theme cart drawer hidden. GoKwik drawer: ensure it stacks above theme (common app selectors). {%- endcomment -%}
      <style>
        #cart-drawer {
          display: none !important;
          visibility: hidden !important;
          pointer-events: none !important;
        }
        [id*="kwik"], [id*="Kwik"], [class*="kwik-cart"], [class*="KwikCart"], [class*="gokwik"], [class*="slide-cart"] {
          z-index: 999999 !important;
        }
      </style>
      <script>
      (function() {
        function keepThemeCartClosed() {
          var el = document.getElementById('cart-drawer');
          if (el) {
            el.classList.remove('active');
            el.setAttribute('aria-hidden', 'true');
            el.style.setProperty('display', 'none', 'important');
