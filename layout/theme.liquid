<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <link rel="icon" type="image/png" href="{{ 'Logo.png' | asset_url }}" sizes="any">
    
    {%- comment -%} Performance: Resource Hints {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    
    {%- comment -%} Performance: Font Loading Optimization {%- endcomment -%}
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"></noscript>
    
    {%- comment -%} Inlined CSS Variables {%- endcomment -%}
    {% render 'css-variables' %}

    {%- comment -%}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {%- endcomment -%}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {%- comment -%} Critical CSS - load normally to avoid "preloaded but not used" console warning {%- endcomment -%}
    {{ 'critical.css' | asset_url | stylesheet_tag }}

    {%- comment -%} SEO Meta Tags {%- endcomment -%}
    {% render 'meta-tags' %}

    {{content_for_header}}
  </head>

  <body class="template-{{ request.page_type | handle }}">
    {%- if request.page_type == 'index' -%}
    <style>
      /* Hide Judge.me floating overlay on home so it doesn't sit on hero */
      body.template-index > div[class*="jdgm"]:not([id^="shopify-section"]),
      body.template-index [class*="jdgm-preview-badge"],
      body.template-index [class*="jdgm-floating"],
      body.template-index [class*="jdgm-float"],
      body.template-index [id*="judge-me"][style*="fixed"],
      body.template-index [class*="jdgm"][style*="position: fixed"],
      body.template-index .hero-banner [class*="jdgm"],
      body.template-index .hero-banner [class*="judge-me"] { display: none !important; visibility: hidden !important; }
    </style>
    {%- endif -%}
    {%- comment -%} Skip to main content link for accessibility {%- endcomment -%}
    <a href="#main-content" class="skip-to-main">{{ 'general.accessibility.skip_to_content' | t | default: 'Skip to main content' }}</a>
    
    {% sections 'header-group' %}

    <main id="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}  
    </main>

    {% sections 'footer-group' %}

    {%- comment -%} Theme cart drawer hidden. GoKwik drawer: ensure it stacks above theme (common app selectors). {%- endcomment -%}
    <style>
      #cart-drawer {
        display: none !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }
      [id*="kwik"], [id*="Kwik"], [class*="kwik-cart"], [class*="KwikCart"], [class*="gokwik"], [class*="slide-cart"] {
        z-index: 999999 !important;
      }
    </style>
    <script>
    (function() {
      function keepThemeCartClosed() {
        var el = document.getElementById('cart-drawer');
        if (el) {
          el.classList.remove('active');
          el.setAttribute('aria-hidden', 'true');
          el.style.setProperty('display', 'none', 'important');
        }
      }
      keepThemeCartClosed();
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', keepThemeCartClosed);
      }
    })();
    </script>
    {%- comment -%} GoKwik: debug – add ?gokwik_debug=1 to any page URL and check console for exposed globals. {%- endcomment -%}
    <script>
    (function() {
      if (typeof window.location !== 'undefined' && window.location.search.indexOf('gokwik_debug=1') !== -1) {
        function logGokwik() {
          var w = window;
          console.log('[GoKwik debug] Globals (check after page + app scripts load):', {
            GoKwik: w.GoKwik,
            KwikCheckout: w.KwikCheckout,
            gokwik: w.gokwik,
            kwikCheckout: w.kwikCheckout,
            gokwikCheckout: w.gokwikCheckout,
            KwikCart: w.KwikCart
          });
          if (w.KwikCheckout && typeof w.KwikCheckout === 'object') {
            console.log('[GoKwik debug] KwikCheckout keys:', Object.keys(w.KwikCheckout));
          }
          if (w.GoKwik && typeof w.GoKwik === 'object') {
            console.log('[GoKwik debug] GoKwik keys:', Object.keys(w.GoKwik));
          }
          var btn = document.querySelector('[data-gokwik-checkout], [data-gkc], [class*="gokwik"][class*="checkout"], [id*="gokwik"][id*="checkout"]');
          console.log('[GoKwik debug] Checkout element in DOM:', btn);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function() { setTimeout(logGokwik, 1500); });
        } else {
          setTimeout(logGokwik, 1500);
        }
      }
    })();
    </script>
    {%- comment -%} GoKwik: block default Shopify checkout; only trigger GoKwik (popup/drawer). {%- endcomment -%}
    <script>
    (function() {
      // Hard-block Shopify checkout navigation (/checkout, /checkouts/*) from theme buttons/JS.
      // If GoKwik doesn't open a popup, it might still redirect; this ensures our buttons never do.
      function _isShopifyCheckoutUrl(u) {
        if (!u) return false;
        var s = String(u);
        return s.indexOf('/checkouts/') !== -1 || s.indexOf('/checkout') !== -1;
      }

      // Guard: if storefront theme is being rendered on a /checkout or /checkouts/* URL,
      // bounce back to cart and attempt GoKwik. (Shopify hosted checkout normally doesn't run theme.liquid,
      // but some setups/apps can route /checkouts/* through storefront.)
      (function() {
        try {
          var p = window.location && window.location.pathname ? String(window.location.pathname) : '';
          var isCheckoutPath = p === '/checkout' || p.indexOf('/checkouts/') === 0;
          var q = window.location && window.location.search ? String(window.location.search) : '';
          var allow = q.indexOf('allow_checkout=1') !== -1;
          if (isCheckoutPath && !allow) {
            // Replace so user can't hit back into the checkout URL loop.
            if (window.location && typeof window.location.replace === 'function') {
              window.location.replace('/cart?open_cart=1&blocked_checkout=1');
            }
          }
        } catch (e) {}
      })();

      function triggerGoKwikCheckout(event) {
        if (event) {
          event.preventDefault();
          event.stopPropagation();
        }
        if (typeof window.gokwikCheckout !== 'undefined' && window.gokwikCheckout && typeof window.gokwikCheckout.open === 'function') {
          window.gokwikCheckout.open();
          return;
        }
        if (typeof window.GoKwik !== 'undefined' && window.GoKwik && typeof window.GoKwik.openCheckout === 'function') {
          window.GoKwik.openCheckout();
          return;
        }
        if (typeof window.KwikCheckout !== 'undefined' && window.KwikCheckout) {
          if (typeof window.KwikCheckout.open === 'function') { window.KwikCheckout.open(); return; }
          if (typeof window.KwikCheckout.show === 'function') { window.KwikCheckout.show(); return; }
          if (typeof window.KwikCheckout.init === 'function') { window.KwikCheckout.init(); return; }
        }
        var gkTrigger = document.querySelector('[data-gokwik-trigger], [data-gokwik-checkout], [data-gkc], .gokwik-checkout-btn, #gokwik-checkout-btn');
        if (gkTrigger) {
          gkTrigger.click();
          return;
        }
        document.dispatchEvent(new CustomEvent('gokwik-open-checkout'));
        if (typeof window.KwikCart !== 'undefined') {
          if (typeof window.KwikCart.open === 'function') window.KwikCart.open();
          if (typeof window.KwikCart.show === 'function') window.KwikCart.show();
          if (typeof window.KwikCart.openCart === 'function') window.KwikCart.openCart();
          return;
        }
        if (typeof window.openCartDrawer === 'function') {
          window.openCartDrawer();
          return;
        }
        var url = new URL(window.location.href);
        url.searchParams.set('open_cart', '1');
        url.searchParams.set('openCart', '1');
        window.location.href = url.pathname + url.search;
      }
      window.triggerGoKwikCheckout = triggerGoKwikCheckout;
      window.openGokwikCheckout = function() { triggerGoKwikCheckout(); };

      // Block programmatic redirects (best-effort; some browsers restrict overriding).
      (function() {
        try {
          var loc = window.location;
          var _assign = loc.assign && loc.assign.bind(loc);
          var _replace = loc.replace && loc.replace.bind(loc);
          if (_assign) {
            loc.assign = function(u) {
              if (_isShopifyCheckoutUrl(u)) return triggerGoKwikCheckout();
              return _assign(u);
            };
          }
          if (_replace) {
            loc.replace = function(u) {
              if (_isShopifyCheckoutUrl(u)) return triggerGoKwikCheckout();
              return _replace(u);
            };
          }
        } catch (err) {}
        // Attempt to block direct href setter (best-effort; may be non-configurable).
        try {
          var proto = window.Location && window.Location.prototype;
          if (proto) {
            var d = Object.getOwnPropertyDescriptor(proto, 'href');
            if (d && d.configurable && typeof d.set === 'function') {
              Object.defineProperty(proto, 'href', {
                configurable: true,
                enumerable: d.enumerable,
                get: d.get,
                set: function(u) {
                  if (_isShopifyCheckoutUrl(u)) return triggerGoKwikCheckout();
                  return d.set.call(this, u);
                }
              });
            }
          }
        } catch (errHref) {}
        try {
          var _submit = HTMLFormElement && HTMLFormElement.prototype && HTMLFormElement.prototype.submit;
          if (_submit) {
            HTMLFormElement.prototype.submit = function() {
              var action = (this.getAttribute('action') || '').toLowerCase();
              if (action.indexOf('checkout') !== -1) {
                triggerGoKwikCheckout();
                return;
              }
              return _submit.apply(this, arguments);
            };
          }
        } catch (err2) {}
      })();

      document.addEventListener('click', function(e) {
        var t = e.target;
        while (t && t !== document.body) {
          if (t.id === 'cart-checkout-btn' || t.getAttribute('data-gokwik-checkout') === 'true') {
            e.preventDefault();
            e.stopPropagation();
            if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
            triggerGoKwikCheckout(e);
            return;
          }
          if (t.nodeName === 'A') {
            var href = t.getAttribute('href') || '';
            if (href === '/checkout' || href.indexOf('/checkout') !== -1 || href.indexOf('/checkouts/') !== -1) {
              e.preventDefault();
              e.stopPropagation();
              if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
              triggerGoKwikCheckout(e);
              return;
            }
          }
          if ((t.nodeName === 'BUTTON' || t.nodeName === 'INPUT') && t.getAttribute('name') === 'checkout') {
            e.preventDefault();
            e.stopPropagation();
            if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
            triggerGoKwikCheckout(e);
            return;
          }
          t = t.parentElement;
        }
      }, true);

      document.addEventListener('submit', function(e) {
        var form = e.target;
        if (!form || form.nodeName !== 'FORM') return;
        var action = (form.getAttribute('action') || '').toLowerCase();
        var submitter = e.submitter;
        if (action.indexOf('checkout') !== -1 || (submitter && (submitter.getAttribute('name') === 'checkout' || submitter.name === 'checkout'))) {
          e.preventDefault();
          e.stopPropagation();
          if (typeof e.stopImmediatePropagation === 'function') e.stopImmediatePropagation();
          triggerGoKwikCheckout(e);
          return false;
        }
      }, true);

      document.addEventListener('DOMContentLoaded', function() {
        var cartBtn = document.getElementById('cart-checkout-btn');
        if (cartBtn) {
          cartBtn.addEventListener('click', function(ev) {
            ev.preventDefault();
            ev.stopPropagation();
            triggerGoKwikCheckout(ev);
          });
        }
      });
    })();
    </script>
    {%- comment -%} openCartDrawer for add-to-cart only. Cart icon uses normal link so GoKwik opens on load (no freeze). {%- endcomment -%}
    <script>
    (function() {
      if (!window.lockBodyScroll) {
        window.lockBodyScroll = function() {
          var scrollY = window.pageYOffset || document.documentElement.scrollTop;
          document.body.style.position = 'fixed';
          document.body.style.top = '-' + scrollY + 'px';
          document.body.style.left = '0';
          document.body.style.right = '0';
          document.body.style.overflow = 'hidden';
          document.body.setAttribute('data-scroll-position', String(scrollY));
        };
      }
      if (!window.unlockBodyScroll) {
        window.unlockBodyScroll = function() {
          var scrollY = document.body.getAttribute('data-scroll-position') || '0';
          document.body.style.position = '';
          document.body.style.top = '';
          document.body.style.left = '';
          document.body.style.right = '';
          document.body.style.overflow = '';
          document.body.removeAttribute('data-scroll-position');
          window.scrollTo(0, parseInt(scrollY, 10));
        };
      }
      /** Open GoKwik drawer (after add-to-cart). Navigate to ?open_cart=1 so drawer opens on load. */
      window.openCartDrawer = function() {
        var url = new URL(window.location.href);
        if (!url.searchParams.has('open_cart')) url.searchParams.set('open_cart', '1');
        if (!url.searchParams.has('openCart')) url.searchParams.set('openCart', '1');
        var newUrl = url.pathname + (url.search ? url.search : '');
        window.location.href = newUrl;
      };
    })();
    </script>
    {%- comment -%} On load with open_cart/openCart: try every way to open GoKwik drawer; unfreeze after 4s if stuck. {%- endcomment -%}
    <script>
    (function() {
      var q = window.location.search || '';
      if (q.indexOf('open_cart=') === -1 && q.indexOf('openCart=') === -1) return;
      var attempts = 0;
      var maxAttempts = 25;
      function tryOpen() {
        attempts++;
        if (typeof window.KwikCart !== 'undefined') {
          if (typeof window.KwikCart.open === 'function') window.KwikCart.open();
          if (typeof window.KwikCart.show === 'function') window.KwikCart.show();
          if (typeof window.KwikCart.openCart === 'function') window.KwikCart.openCart();
        }
        if (attempts === 3) {
          document.dispatchEvent(new CustomEvent('open-cart-drawer'));
          document.dispatchEvent(new CustomEvent('openCart'));
          document.dispatchEvent(new CustomEvent('cart:open'));
        }
        if (attempts < maxAttempts) setTimeout(tryOpen, 250);
      }
      function unfreezeIfNeeded() {
        if (document.body && document.body.style && document.body.style.position === 'fixed') {
          if (typeof window.unlockBodyScroll === 'function') window.unlockBodyScroll();
          else {
            document.body.style.position = '';
            document.body.style.top = '';
            document.body.style.overflow = '';
            document.body.removeAttribute('data-scroll-position');
          }
        }
      }
      function run() {
        tryOpen();
        setTimeout(unfreezeIfNeeded, 4000);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
      } else {
        run();
      }
    })();
    </script>

    {%- comment -%} Move mobile menu drawer to end of body so it always stacks above hero/carousel {%- endcomment -%}
    <script>
      (function() {
        var drawer = document.getElementById('mobile-menu-drawer');
        if (drawer && drawer.parentNode && document.body) document.body.appendChild(drawer);
      })();
    </script>

    {%- comment -%} Header + Cart: single inline script so hamburger and cart work (runs after header/cart in DOM) {%- endcomment -%}
    <script>
      (function() {
        var cartListenerAdded = false;
        var menuAttached = false;
        // iOS Safari: overflow:hidden doesn't lock scroll; position:fixed + save/restore scrollY does
        window.lockBodyScroll = function() {
          var scrollY = window.pageYOffset || document.documentElement.scrollTop;
          document.body.style.position = 'fixed';
          document.body.style.top = '-' + scrollY + 'px';
          document.body.style.left = '0';
          document.body.style.right = '0';
          document.body.style.overflow = 'hidden';
          document.body.setAttribute('data-scroll-position', String(scrollY));
        };
        window.unlockBodyScroll = function() {
          var scrollY = document.body.getAttribute('data-scroll-position') || '0';
          document.body.style.position = '';
          document.body.style.top = '';
          document.body.style.left = '';
          document.body.style.right = '';
          document.body.style.overflow = '';
          document.body.removeAttribute('data-scroll-position');
          window.scrollTo(0, parseInt(scrollY, 10));
        };
        function initHeaderAndCart() {
          var doc = document;

          // --- Cart: no theme intercept; link is href="/cart" so GoKwik can intercept and open drawer. ---
          if (!cartListenerAdded) cartListenerAdded = true;

          // --- Hamburger / Mobile menu: use event delegation so it works even if header loads late ---
          if (!menuAttached) {
            var menuDrawer = doc.querySelector('[data-mobile-menu]');
            if (menuDrawer) {
              menuAttached = true;
              var menuToggle = doc.querySelector('[data-mobile-menu-toggle]');
              function openMenu(toggle, drawer) {
                if (toggle) {
                  toggle.classList.add('active');
                  toggle.setAttribute('aria-expanded', 'true');
                  toggle.setAttribute('aria-label', 'Close menu');
                }
                drawer.classList.add('active');
                drawer.setAttribute('aria-hidden', 'false');
                if (window.lockBodyScroll) window.lockBodyScroll();
                else doc.body.style.overflow = 'hidden';
              }
              function closeMenu(toggle, drawer) {
                if (toggle) {
                  toggle.classList.remove('active');
                  toggle.setAttribute('aria-expanded', 'false');
                  toggle.setAttribute('aria-label', 'Open menu');
                }
                drawer.classList.remove('active');
                drawer.setAttribute('aria-hidden', 'true');
                if (window.unlockBodyScroll) window.unlockBodyScroll();
                else doc.body.style.overflow = '';
              }
              doc.addEventListener('click', function(e) {
                var toggle = e.target && e.target.closest ? e.target.closest('[data-mobile-menu-toggle]') : null;
                if (toggle) {
                  e.preventDefault();
                  e.stopPropagation();
                  var drawer = doc.querySelector('[data-mobile-menu]');
                  if (drawer) {
                    if (drawer.classList.contains('active')) {
                      closeMenu(toggle, drawer);
                    } else {
                      openMenu(toggle, drawer);
                    }
                  }
                }
                var closeBtn = e.target && e.target.closest ? e.target.closest('[data-mobile-menu-close]') : null;
                if (closeBtn) {
                  e.preventDefault();
                  e.stopPropagation();
                  var d = doc.querySelector('[data-mobile-menu]');
                  var t = doc.querySelector('[data-mobile-menu-toggle]');
                  if (d) closeMenu(t, d);
                }
              }, true);
              menuDrawer.addEventListener('click', function(e) {
                var overlay = e.target && e.target.closest ? e.target.closest('.mobile-menu-overlay') : null;
                if (overlay) {
                  e.preventDefault();
                  e.stopPropagation();
                  var d = doc.querySelector('[data-mobile-menu]');
                  var t = doc.querySelector('[data-mobile-menu-toggle]');
                  if (d) closeMenu(t, d);
                  return;
                }
                var subToggle = e.target && e.target.closest ? e.target.closest('.mobile-nav-toggle') : null;
                if (subToggle) {
                  e.preventDefault();
                  var item = subToggle.closest('.mobile-nav-item');
                  if (item) {
                    item.classList.toggle('active');
                    subToggle.setAttribute('aria-expanded', item.classList.contains('active'));
                  }
                }
              });
              /* iOS: handle menu toggle on touchend so it responds without 300ms delay or missed tap */
              doc.addEventListener('touchend', function(e) {
                var toggle = e.target && e.target.closest ? e.target.closest('[data-mobile-menu-toggle]') : null;
                if (!toggle) return;
                var drawer = doc.querySelector('[data-mobile-menu]');
                if (!drawer) return;
                e.preventDefault();
                if (drawer.classList.contains('active')) closeMenu(toggle, drawer);
                else openMenu(toggle, drawer);
              }, { passive: false });
            }
          }
        }
        initHeaderAndCart();
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHeaderAndCart);
        }
      })();
    </script>

    {%- comment -%} Base JavaScript. Error at scripts.js:760 is in compiled_assets/scripts.js; theme loads application.js so that file is not used here. {%- endcomment -%}
    <script src="{{ 'application.js' | asset_url }}" defer></script>
    {%- comment -%} Cart page +/- and remove: event delegation in capture phase so it runs before other handlers {%- endcomment -%}
    <script>
      (function() {
        function handleCartPageClick(e) {
          var btn = e.target && e.target.closest ? e.target.closest('button[data-cart-increase], button[data-cart-decrease], [data-cart-remove]') : null;
          if (!btn) return;
          var row = btn.closest ? btn.closest('.cart-item-row') : null;
          if (!row) return;
          e.preventDefault();
          e.stopPropagation();
          var key, qty;
          if (btn.hasAttribute && btn.hasAttribute('data-cart-increase')) {
            key = btn.getAttribute('data-cart-increase');
            var valEl = row.querySelector('[data-cart-quantity-value]');
            var cur = valEl ? (parseInt(valEl.textContent, 10) || 1) : 1;
            qty = cur + 1;
            if (valEl) valEl.textContent = qty;
            var inp = row.querySelector('input[data-cart-quantity]');
            if (inp) inp.value = qty;
          } else if (btn.hasAttribute && btn.hasAttribute('data-cart-decrease')) {
            key = btn.getAttribute('data-cart-decrease');
            var valEl2 = row.querySelector('[data-cart-quantity-value]');
            var cur2 = valEl2 ? (parseInt(valEl2.textContent, 10) || 1) : 1;
            if (cur2 <= 1) return;
            qty = cur2 - 1;
            if (valEl2) valEl2.textContent = qty;
            var inp2 = row.querySelector('input[data-cart-quantity]');
            if (inp2) inp2.value = qty;
          } else if (btn.hasAttribute && btn.hasAttribute('data-cart-remove')) {
            key = btn.getAttribute('data-cart-remove');
            if (!confirm('Remove this item from cart?')) return;
            qty = 0;
          } else return;
          fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ id: String(key), quantity: qty })
          })
          .then(function(r) {
            if (!r.ok) return r.json().then(function(err) { throw new Error(err.description || 'Cart update failed'); });
            return r.json();
          })
          .then(function() { window.location.reload(); })
          .catch(function(err) { console.error('Cart update error:', err); window.location.reload(); });
        }
        document.addEventListener('click', handleCartPageClick, true);
      })();
    </script>
    {%- comment -%} Product page quantity +/-: capture phase so it always runs {%- endcomment -%}
    <script>
      (function() {
        function handleProductQuantityClick(e) {
          var btn = e.target && e.target.closest ? e.target.closest('button.quantity-btn[data-action]') : null;
          if (!btn) return;
          var form = btn.closest ? btn.closest('#product-form') : null;
          if (!form) return;
          var selector = btn.closest ? btn.closest('.quantity-selector') : null;
          var inp = selector ? selector.querySelector('input[name="quantity"], input.quantity-input') : null;
          if (!inp) return;
          e.preventDefault();
          e.stopPropagation();
          var action = btn.getAttribute('data-action');
          var cur = parseInt(inp.value, 10) || 1;
          var min = parseInt(inp.getAttribute('min'), 10) || 1;
          var max = parseInt(inp.getAttribute('max'), 10) || 10;
          if (action === 'increase' && cur < max) {
            inp.value = cur + 1;
          } else if (action === 'decrease' && cur > min) {
            inp.value = cur - 1;
          }
        }
        document.addEventListener('click', handleProductQuantityClick, true);
      })();
    </script>
    {%- comment -%} Product cards: show quantity only after add-to-cart; +/- updates cart via change.js {%- endcomment -%}
    <script>
      (function() {
        function showProductCardQtyRow(form, lineKey, quantity) {
          if (lineKey) form.setAttribute('data-line-key', lineKey);
          var qtyRow = form.querySelector('.product-card__quantity-row');
          if (qtyRow) {
            qtyRow.classList.remove('product-card__quantity-row--hidden');
            qtyRow.style.display = 'flex';
            qtyRow.style.visibility = 'visible';
          }
          var qtyInput = form.querySelector('.product-card__qty-input');
          if (qtyInput) qtyInput.value = quantity || 1;
        }
        function doProductCardAddToCart(form) {
          var idInput = form.querySelector('input[name="id"]');
          var qtyInput = form.querySelector('input[name="quantity"]');
          var variantId = idInput ? idInput.value : null;
          if (!variantId) return;
          var submitBtn = form.querySelector('button[type="submit"][name="add"]');
          var originalText = submitBtn ? submitBtn.textContent : '';
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Adding...';
          }
          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: variantId, quantity: 1 })
          }).then(function(r) { return r.json().then(function(data) { return { ok: r.ok, data: data }; }); }).then(function(result) {
            if (result.ok) {
              var data = result.data || result;
              var key = (data && data.key) || null;
              var qty = (data && (data.quantity != null)) ? data.quantity : 1;
              function done() {
                document.dispatchEvent(new CustomEvent('cart:updated'));
                // Do not open side cart on add — let user continue shopping; they can open cart via header icon
              }
              if (!key) {
                fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
                  var item = (cart.items || []).find(function(i) { return String(i.variant_id) === String(variantId) || String(i.id) === String(variantId); });
                  key = item ? item.key : null;
                  showProductCardQtyRow(form, key, item ? item.quantity : qty);
                  done();
                }).catch(function() { showProductCardQtyRow(form, null, qty); done(); });
              } else {
                showProductCardQtyRow(form, key, qty);
                done();
              }
            } else {
              alert((result.data && result.data.description) || (result.description) || 'Could not add to cart.');
            }
          }).catch(function() { alert('Could not add to cart.'); }).then(function() {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = originalText;
            }
          });
        }
        document.addEventListener('click', function(e) {
          var addBtn = e.target && e.target.closest ? e.target.closest('button.product-card__add-to-cart') : null;
          if (addBtn) {
            var form = addBtn.closest('form.product-card__form');
            if (form) {
              e.preventDefault();
              e.stopPropagation();
              doProductCardAddToCart(form);
              return;
            }
          }
          if (e.target && e.target.closest && e.target.closest('form.product-card__form')) {
            e.stopPropagation();
          }
        }, true);
        document.addEventListener('click', function(e) {
          var btn = e.target && e.target.closest ? e.target.closest('.product-card__qty-btn') : null;
          if (!btn) return;
          var selector = btn.closest ? btn.closest('.product-card__quantity-selector') : null;
          var inp = selector ? selector.querySelector('.product-card__qty-input') : null;
          var form = btn.closest ? btn.closest('form.product-card__form') : null;
          if (!inp || !form) return;
          e.preventDefault();
          e.stopPropagation();
          var action = btn.getAttribute('data-action');
          var cur = parseInt(inp.value, 10) || 1;
          var max = parseInt(inp.getAttribute('max'), 10) || 10;
          var lineKey = form.getAttribute('data-line-key');
          if (lineKey) {
            var newQty = action === 'increase' ? (cur < max ? cur + 1 : cur) : (cur > 0 ? cur - 1 : 0);
            if (action === 'increase' && cur >= max) return;
            btn.disabled = true;
            // Prefer updating cart line by variant id for broader compatibility; fall back to line key if needed
            var idInput = form.querySelector('input[name=\"id\"]');
            var variantId = idInput ? idInput.value : null;
            var changePayload = { id: variantId || lineKey, quantity: newQty };
            fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(changePayload)
            }).then(function(r) { return r.json().then(function(data) { return { ok: r.ok, data: data }; }); }).then(function(result) {
              if (result.ok) {
                inp.value = newQty;
                document.dispatchEvent(new CustomEvent('cart:updated'));
                if (newQty === 0) {
                  form.removeAttribute('data-line-key');
                  var qtyRow = form.querySelector('.product-card__quantity-row');
                  if (qtyRow) {
                    qtyRow.classList.add('product-card__quantity-row--hidden');
                    qtyRow.style.display = '';
                    qtyRow.style.visibility = '';
                  }
                }
              } else {
                alert(result.data && result.data.description ? result.data.description : 'Could not update cart.');
              }
            }).catch(function() { alert('Could not update cart.'); }).then(function() { btn.disabled = false; });
            return;
          }
          var min = parseInt(inp.getAttribute('min'), 10) || 0;
          if (action === 'increase' && cur < max) inp.value = cur + 1;
          else if (action === 'decrease' && cur > min) inp.value = cur - 1;
        }, true);
        document.addEventListener('submit', function(e) {
          if (!e.target || !e.target.classList || !e.target.classList.contains('product-card__form')) return;
          e.preventDefault();
          e.stopPropagation();
          doProductCardAddToCart(e.target);
        }, true);
        // On load: if product is already in cart, show quantity row on each product card
        function syncProductCardsWithCart() {
          fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
            var items = cart.items || [];
            var forms = document.querySelectorAll('form.product-card__form');
            for (var i = 0; i < forms.length; i++) {
              var form = forms[i];
              var idInput = form.querySelector('input[name="id"]');
              var variantId = idInput ? idInput.value : null;
              if (!variantId) continue;
              var item = items.find(function(it) { return String(it.variant_id) === String(variantId) || String(it.id) === String(variantId); });
              if (item) showProductCardQtyRow(form, item.key, item.quantity);
            }
          }).catch(function() {});
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', syncProductCardsWithCart);
        } else {
          syncProductCardsWithCart();
        }
        document.addEventListener('cart:updated', syncProductCardsWithCart);
      })();
    </script>
    {%- comment -%} Product page: thumbnail gallery + zoom lightbox (inline so it always runs after DOM) {%- endcomment -%}
    {% if request.page_type == 'product' %}
    <style>
      #product-image-lightbox {
        position: fixed;
        inset: 0;
        inset: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
        z-index: 9999;
        background: rgba(0, 0, 0, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        box-sizing: border-box;
      }
      #product-image-lightbox .product-lightbox-inner {
        max-width: 90vw;
        max-height: 90vh;
        max-height: 90dvh;
        position: relative;
      }
      #product-image-lightbox .product-lightbox-img {
        max-width: 100%;
        max-height: 90vh;
        max-height: 90dvh;
        width: auto;
        height: auto;
        object-fit: contain;
      }
      #product-image-lightbox .product-lightbox-close {
        position: absolute;
        top: max(16px, env(safe-area-inset-top));
        right: max(16px, env(safe-area-inset-right));
        width: 48px;
        height: 48px;
        border: none;
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
        font-size: 24px;
        line-height: 1;
        cursor: pointer;
        border-radius: 50%;
        z-index: 10;
        transition: background 0.2s;
      }
      #product-image-lightbox .product-lightbox-close:hover {
        background: rgba(255, 255, 255, 0.35);
      }
    </style>
    <script>
      (function() {
        function openLightbox(src, alt) {
          if (document.getElementById('product-image-lightbox')) return;
          var overlay = document.createElement('div');
          overlay.id = 'product-image-lightbox';
          overlay.setAttribute('role', 'dialog');
          overlay.setAttribute('aria-modal', 'true');
          overlay.setAttribute('aria-label', 'Zoomed product image');
          overlay.innerHTML = '<button type="button" class="product-lightbox-close" aria-label="Close">&times;</button><div class="product-lightbox-inner"><img src="" alt="" class="product-lightbox-img"></div>';
          var im = overlay.querySelector('.product-lightbox-img');
          im.src = src;
          im.alt = alt;
          document.body.appendChild(overlay);
          if (window.lockBodyScroll) window.lockBodyScroll();
          else document.body.style.overflow = 'hidden';
          function closeLightbox() {
            if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
            if (window.unlockBodyScroll) window.unlockBodyScroll();
            else document.body.style.overflow = '';
            document.removeEventListener('keydown', onKey);
          }
          function onKey(ev) {
            if (ev.key === 'Escape') closeLightbox();
          }
          overlay.addEventListener('click', function(ev) {
            if (ev.target === overlay || ev.target.classList.contains('product-lightbox-close')) closeLightbox();
          });
          document.addEventListener('keydown', onKey);
        }
        document.addEventListener('product-zoom-image', function(e) {
          if (e.detail && e.detail.src) openLightbox(e.detail.src, e.detail.alt || '');
        });
      })();
    </script>
    {% endif %}
  </body>
</html>
