<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <link rel="icon" type="image/png" href="{{ 'Logo.png' | asset_url }}" sizes="any">
    
    {%- comment -%} Performance: Resource Hints {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    
    {%- comment -%} Performance: Font Loading Optimization {%- endcomment -%}
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"></noscript>
    
    {%- comment -%} Inlined CSS Variables {%- endcomment -%}
    {% render 'css-variables' %}

    {%- comment -%}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {%- endcomment -%}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {%- comment -%} Critical CSS - load normally to avoid "preloaded but not used" console warning {%- endcomment -%}
    {{ 'critical.css' | asset_url | stylesheet_tag }}

    {%- comment -%} SEO Meta Tags {%- endcomment -%}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body class="template-{{ request.page_type | handle }}">
    {%- comment -%} Skip to main content link for accessibility {%- endcomment -%}
    <a href="#main-content" class="skip-to-main">{{ 'general.accessibility.skip_to_content' | t | default: 'Skip to main content' }}</a>
    
    {% sections 'header-group' %}

    <main id="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- comment -%} Cart Drawer (markup + inline script so it always works; not dependent on snippet bundle) {%- endcomment -%}
    {% render 'cart-drawer' %}
    <script>
    (function() {
      'use strict';
      var cartDrawer = document.getElementById('cart-drawer');
      if (!cartDrawer) return;
      var cartDrawerClose = document.querySelectorAll('[data-cart-drawer-close]');
      var cartItems = document.querySelector('[data-cart-items]');
      var cartEmpty = document.querySelector('[data-cart-empty]');
      var cartLoading = document.querySelector('[data-cart-loading]');
      var cartFooter = document.querySelector('[data-cart-footer]');
      var cartSubtotal = document.querySelector('[data-cart-subtotal]');
      var cartTotal = document.querySelector('[data-cart-total]');
      var cartCheckout = document.querySelector('[data-cart-checkout]');

      function openCartDrawer() {
        cartDrawer.classList.add('active');
        if (window.lockBodyScroll) window.lockBodyScroll();
        else document.body.style.overflow = 'hidden';
        if (cartLoading) cartLoading.classList.add('active');
        if (cartItems) { cartItems.classList.remove('active'); }
        if (cartEmpty) cartEmpty.classList.remove('active');
        if (cartFooter) cartFooter.style.display = 'none';
        setTimeout(function() { loadCart(); }, 0);
      }
      function closeCartDrawer() {
        cartDrawer.classList.remove('active');
        if (window.unlockBodyScroll) window.unlockBodyScroll();
        else document.body.style.overflow = '';
      }
      function loadCart() {
        if (!cartLoading || !cartItems || !cartEmpty || !cartFooter) return;
        cartLoading.classList.add('active');
        cartItems.classList.remove('active');
        cartEmpty.classList.remove('active');
        cartFooter.style.display = 'none';
        fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
          cartLoading.classList.remove('active');
          renderCart(cart);
        }).catch(function(err) {
          console.error('Cart load error:', err);
          cartLoading.classList.remove('active');
        });
      }
      function formatMoney(cents) {
        try {
          return new Intl.NumberFormat(document.documentElement.lang || 'en-US', { style: 'currency', currency: '{{ cart.currency.iso_code | default: "INR" }}' }).format((parseInt(cents, 10) || 0) / 100);
        } catch (e) {
          return (parseInt(cents, 10) / 100).toFixed(2);
        }
      }
      function renderCart(cart) {
        if (!cartItems || !cartEmpty || !cartFooter) return;
        if (cart.item_count === 0) {
          cartItems.innerHTML = '';
          cartItems.classList.remove('active');
          cartEmpty.classList.add('active');
          cartFooter.style.display = 'none';
          return;
        }
        cartEmpty.classList.remove('active');
        cartFooter.style.display = 'block';
        var itemsHtml = cart.items.map(function(item) {
          var v = item.variant_title !== 'Default Title' ? '<div class="cart-item-variant">' + item.variant_title + '</div>' : '';
          return '<div class="cart-item" data-cart-item="' + item.key + '"><div class="cart-item-image"><img src="' + item.image + '" alt="' + (item.product_title || '').replace(/"/g, '&quot;') + '" loading="lazy"></div><div class="cart-item-details"><h4 class="cart-item-title"><a href="' + item.url + '">' + (item.product_title || '').replace(/</g, '&lt;') + '</a></h4>' + v + '<div class="cart-item-price">' + formatMoney(item.line_price) + '</div><div class="cart-item-actions"><div class="cart-item-quantity"><button type="button" data-cart-decrease="' + item.key + '" aria-label="Decrease">−</button><span class="cart-item-quantity__value" data-cart-quantity-value="' + item.key + '">' + (Number(item.quantity) || 1) + '</span><button type="button" data-cart-increase="' + item.key + '" aria-label="Increase">+</button></div><button type="button" class="cart-item-remove" data-cart-remove="' + item.key + '" aria-label="Remove">Remove</button></div></div></div>';
        }).join('');
        cartItems.innerHTML = itemsHtml;
        cartItems.classList.add('active');
        if (cartSubtotal) cartSubtotal.textContent = formatMoney(cart.total_price);
        if (cartTotal) cartTotal.textContent = formatMoney(cart.total_price);
      }
      function updateCartCount() {
        fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
          var el = document.querySelector('[data-cart-count]');
          if (el) {
            el.textContent = cart.item_count;
            el.style.display = cart.item_count > 0 ? 'block' : 'none';
          }
        });
      }
      function updateCartItem(key, qty) {
        fetch('/cart/change.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: key, quantity: qty }) })
          .then(function(r) { return r.json(); }).then(function(cart) { renderCart(cart); updateCartCount(); document.dispatchEvent(new CustomEvent('cart:updated')); }).catch(function(e) { console.error(e); });
      }
      function removeCartItem(key) {
        fetch('/cart/change.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: key, quantity: 0 }) })
          .then(function(r) { return r.json(); }).then(function(cart) { renderCart(cart); updateCartCount(); document.dispatchEvent(new CustomEvent('cart:updated')); }).catch(function(e) { console.error(e); });
      }
      if (cartItems && !cartItems._cartDelegation) {
        cartItems._cartDelegation = true;
        cartItems.addEventListener('click', function(e) {
          var inc = e.target && e.target.closest ? e.target.closest('[data-cart-increase]') : null;
          var dec = e.target && e.target.closest ? e.target.closest('[data-cart-decrease]') : null;
          var rem = e.target && e.target.closest ? e.target.closest('[data-cart-remove]') : null;
          if (inc) { e.preventDefault(); e.stopPropagation(); var k = inc.getAttribute('data-cart-increase'); var c = inc.closest('.cart-item-quantity'); var v = c && c.querySelector('[data-cart-quantity-value]'); var n = v ? (parseInt(v.textContent, 10) || 1) + 1 : 1; updateCartItem(k, n); }
          else if (dec) { e.preventDefault(); e.stopPropagation(); var k = dec.getAttribute('data-cart-decrease'); var c = dec.closest('.cart-item-quantity'); var v = c && c.querySelector('[data-cart-quantity-value]'); var n = v ? (parseInt(v.textContent, 10) || 1) - 1 : 0; if (n > 0) updateCartItem(k, n); }
          else if (rem) { e.preventDefault(); e.stopPropagation(); removeCartItem(rem.getAttribute('data-cart-remove')); }
        });
      }
      document.addEventListener('open-cart-drawer', openCartDrawer);
      document.addEventListener('cart:updated', function() { if (cartDrawer.classList.contains('active')) loadCart(); });
      for (var i = 0; i < cartDrawerClose.length; i++) cartDrawerClose[i].addEventListener('click', closeCartDrawer);
      cartDrawer.addEventListener('click', function(e) { if (e.target && e.target.classList && e.target.classList.contains('cart-drawer-overlay')) closeCartDrawer(); });
      if (cartCheckout) cartCheckout.addEventListener('click', function() { window.location.href = '/checkout'; });
      window.openCartDrawer = openCartDrawer;
      if (cartDrawer.classList.contains('active')) loadCart();
    })();
    </script>

    {%- comment -%} Move mobile menu drawer to end of body so it always stacks above hero/carousel {%- endcomment -%}
    <script>
      (function() {
        var drawer = document.getElementById('mobile-menu-drawer');
        if (drawer && drawer.parentNode && document.body) document.body.appendChild(drawer);
      })();
    </script>

    {%- comment -%} Header + Cart: single inline script so hamburger and cart work (runs after header/cart in DOM) {%- endcomment -%}
    <script>
      (function() {
        var cartListenerAdded = false;
        var menuAttached = false;
        // iOS Safari: overflow:hidden doesn't lock scroll; position:fixed + save/restore scrollY does
        window.lockBodyScroll = function() {
          var scrollY = window.pageYOffset || document.documentElement.scrollTop;
          document.body.style.position = 'fixed';
          document.body.style.top = '-' + scrollY + 'px';
          document.body.style.left = '0';
          document.body.style.right = '0';
          document.body.style.overflow = 'hidden';
          document.body.setAttribute('data-scroll-position', String(scrollY));
        };
        window.unlockBodyScroll = function() {
          var scrollY = document.body.getAttribute('data-scroll-position') || '0';
          document.body.style.position = '';
          document.body.style.top = '';
          document.body.style.left = '';
          document.body.style.right = '';
          document.body.style.overflow = '';
          document.body.removeAttribute('data-scroll-position');
          window.scrollTo(0, parseInt(scrollY, 10));
        };
        function initHeaderAndCart() {
          var doc = document;

          // --- Cart: run once; open drawer and trigger load (capture phase so it runs first) ---
          if (!cartListenerAdded) {
            cartListenerAdded = true;
            if (typeof window.openCartDrawer !== 'function') {
              window.openCartDrawer = function() {
                var d = doc.getElementById('cart-drawer');
                if (d) {
                  d.classList.add('active');
                  if (window.lockBodyScroll) window.lockBodyScroll();
                  else doc.body.style.overflow = 'hidden';
                }
              };
            }
            doc.addEventListener('click', function(e) {
              var toggle = e.target && e.target.closest ? e.target.closest('[data-cart-toggle]') : null;
              if (!toggle) return;
              e.preventDefault();
              e.stopPropagation();
              var drawer = doc.getElementById('cart-drawer');
              if (!drawer) return;
              drawer.classList.add('active');
              if (window.lockBodyScroll) window.lockBodyScroll();
              else doc.body.style.overflow = 'hidden';
              if (typeof window.openCartDrawer === 'function') {
                try { window.openCartDrawer(); } catch (err) { /* ignore */ }
              } else {
                doc.dispatchEvent(new CustomEvent('open-cart-drawer'));
              }
            }, true);
          }

          // --- Hamburger / Mobile menu: use event delegation so it works even if header loads late ---
          if (!menuAttached) {
            var menuDrawer = doc.querySelector('[data-mobile-menu]');
            if (menuDrawer) {
              menuAttached = true;
              var menuToggle = doc.querySelector('[data-mobile-menu-toggle]');
              function openMenu(toggle, drawer) {
                if (toggle) {
                  toggle.classList.add('active');
                  toggle.setAttribute('aria-expanded', 'true');
                  toggle.setAttribute('aria-label', 'Close menu');
                }
                drawer.classList.add('active');
                drawer.setAttribute('aria-hidden', 'false');
                if (window.lockBodyScroll) window.lockBodyScroll();
                else doc.body.style.overflow = 'hidden';
              }
              function closeMenu(toggle, drawer) {
                if (toggle) {
                  toggle.classList.remove('active');
                  toggle.setAttribute('aria-expanded', 'false');
                  toggle.setAttribute('aria-label', 'Open menu');
                }
                drawer.classList.remove('active');
                drawer.setAttribute('aria-hidden', 'true');
                if (window.unlockBodyScroll) window.unlockBodyScroll();
                else doc.body.style.overflow = '';
              }
              doc.addEventListener('click', function(e) {
                var toggle = e.target && e.target.closest ? e.target.closest('[data-mobile-menu-toggle]') : null;
                if (toggle) {
                  e.preventDefault();
                  e.stopPropagation();
                  var drawer = doc.querySelector('[data-mobile-menu]');
                  if (drawer) {
                    if (drawer.classList.contains('active')) {
                      closeMenu(toggle, drawer);
                    } else {
                      openMenu(toggle, drawer);
                    }
                  }
                }
                var closeBtn = e.target && e.target.closest ? e.target.closest('[data-mobile-menu-close]') : null;
                if (closeBtn) {
                  e.preventDefault();
                  e.stopPropagation();
                  var d = doc.querySelector('[data-mobile-menu]');
                  var t = doc.querySelector('[data-mobile-menu-toggle]');
                  if (d) closeMenu(t, d);
                }
              }, true);
              menuDrawer.addEventListener('click', function(e) {
                var overlay = e.target && e.target.closest ? e.target.closest('.mobile-menu-overlay') : null;
                if (overlay) {
                  e.preventDefault();
                  e.stopPropagation();
                  var d = doc.querySelector('[data-mobile-menu]');
                  var t = doc.querySelector('[data-mobile-menu-toggle]');
                  if (d) closeMenu(t, d);
                  return;
                }
                var subToggle = e.target && e.target.closest ? e.target.closest('.mobile-nav-toggle') : null;
                if (subToggle) {
                  e.preventDefault();
                  var item = subToggle.closest('.mobile-nav-item');
                  if (item) {
                    item.classList.toggle('active');
                    subToggle.setAttribute('aria-expanded', item.classList.contains('active'));
                  }
                }
              });
              /* iOS: handle menu toggle on touchend so it responds without 300ms delay or missed tap */
              doc.addEventListener('touchend', function(e) {
                var toggle = e.target && e.target.closest ? e.target.closest('[data-mobile-menu-toggle]') : null;
                if (!toggle) return;
                var drawer = doc.querySelector('[data-mobile-menu]');
                if (!drawer) return;
                e.preventDefault();
                if (drawer.classList.contains('active')) closeMenu(toggle, drawer);
                else openMenu(toggle, drawer);
              }, { passive: false });
            }
          }
        }
        initHeaderAndCart();
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHeaderAndCart);
        }
      })();
    </script>

    {%- comment -%} Base JavaScript. Error at scripts.js:760 is in compiled_assets/scripts.js; theme loads application.js so that file is not used here. {%- endcomment -%}
    <script src="{{ 'application.js' | asset_url }}" defer></script>
    {%- comment -%} Cart page +/- and remove: event delegation in capture phase so it runs before other handlers {%- endcomment -%}
    <script>
      (function() {
        function handleCartPageClick(e) {
          var btn = e.target && e.target.closest ? e.target.closest('button[data-cart-increase], button[data-cart-decrease], [data-cart-remove]') : null;
          if (!btn) return;
          var row = btn.closest ? btn.closest('.cart-item-row') : null;
          if (!row) return;
          e.preventDefault();
          e.stopPropagation();
          var key, qty;
          if (btn.hasAttribute && btn.hasAttribute('data-cart-increase')) {
            key = btn.getAttribute('data-cart-increase');
            var valEl = row.querySelector('[data-cart-quantity-value]');
            var cur = valEl ? (parseInt(valEl.textContent, 10) || 1) : 1;
            qty = cur + 1;
            if (valEl) valEl.textContent = qty;
            var inp = row.querySelector('input[data-cart-quantity]');
            if (inp) inp.value = qty;
          } else if (btn.hasAttribute && btn.hasAttribute('data-cart-decrease')) {
            key = btn.getAttribute('data-cart-decrease');
            var valEl2 = row.querySelector('[data-cart-quantity-value]');
            var cur2 = valEl2 ? (parseInt(valEl2.textContent, 10) || 1) : 1;
            if (cur2 <= 1) return;
            qty = cur2 - 1;
            if (valEl2) valEl2.textContent = qty;
            var inp2 = row.querySelector('input[data-cart-quantity]');
            if (inp2) inp2.value = qty;
          } else if (btn.hasAttribute && btn.hasAttribute('data-cart-remove')) {
            key = btn.getAttribute('data-cart-remove');
            if (!confirm('Remove this item from cart?')) return;
            qty = 0;
          } else return;
          fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ id: String(key), quantity: qty })
          })
          .then(function(r) {
            if (!r.ok) return r.json().then(function(err) { throw new Error(err.description || 'Cart update failed'); });
            return r.json();
          })
          .then(function() { window.location.reload(); })
          .catch(function(err) { console.error('Cart update error:', err); window.location.reload(); });
        }
        document.addEventListener('click', handleCartPageClick, true);
      })();
    </script>
    {%- comment -%} Product page quantity +/-: capture phase so it always runs {%- endcomment -%}
    <script>
      (function() {
        function handleProductQuantityClick(e) {
          var btn = e.target && e.target.closest ? e.target.closest('button.quantity-btn[data-action]') : null;
          if (!btn) return;
          var form = btn.closest ? btn.closest('#product-form') : null;
          if (!form) return;
          var selector = btn.closest ? btn.closest('.quantity-selector') : null;
          var inp = selector ? selector.querySelector('input[name="quantity"], input.quantity-input') : null;
          if (!inp) return;
          e.preventDefault();
          e.stopPropagation();
          var action = btn.getAttribute('data-action');
          var cur = parseInt(inp.value, 10) || 1;
          var min = parseInt(inp.getAttribute('min'), 10) || 1;
          var max = parseInt(inp.getAttribute('max'), 10) || 10;
          if (action === 'increase' && cur < max) {
            inp.value = cur + 1;
          } else if (action === 'decrease' && cur > min) {
            inp.value = cur - 1;
          }
        }
        document.addEventListener('click', handleProductQuantityClick, true);
      })();
    </script>
    {%- comment -%} Product cards: quantity +/- and AJAX add to cart (collection/search grids) {%- endcomment -%}
    <script>
      (function() {
        document.addEventListener('click', function(e) {
          var btn = e.target && e.target.closest ? e.target.closest('.product-card__qty-btn') : null;
          if (!btn) return;
          var selector = btn.closest ? btn.closest('.product-card__quantity-selector') : null;
          var inp = selector ? selector.querySelector('.product-card__qty-input') : null;
          if (!inp) return;
          e.preventDefault();
          e.stopPropagation();
          var action = btn.getAttribute('data-action');
          var cur = parseInt(inp.value, 10) || 1;
          var min = parseInt(inp.getAttribute('min'), 10) || 1;
          var max = parseInt(inp.getAttribute('max'), 10) || 10;
          if (action === 'increase' && cur < max) inp.value = cur + 1;
          else if (action === 'decrease' && cur > min) inp.value = cur - 1;
        }, true);
        document.addEventListener('submit', function(e) {
          if (!e.target || !e.target.classList || !e.target.classList.contains('product-card__form')) return;
          e.preventDefault();
          e.stopPropagation();
          var form = e.target;
          var idInput = form.querySelector('input[name="id"]');
          var qtyInput = form.querySelector('input[name="quantity"]');
          var variantId = idInput ? idInput.value : null;
          var quantity = (qtyInput && parseInt(qtyInput.value, 10)) || 1;
          if (!variantId) return;
          var submitBtn = form.querySelector('button[type="submit"][name="add"]');
          var originalText = submitBtn ? submitBtn.textContent : '';
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Adding...';
          }
          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: variantId, quantity: quantity })
          }).then(function(r) { return r.json().then(function(data) { return { ok: r.ok, data: data }; }); }).then(function(result) {
            if (result.ok) {
              document.dispatchEvent(new CustomEvent('cart:updated'));
              if (typeof window.openCartDrawer === 'function') window.openCartDrawer();
              else document.dispatchEvent(new CustomEvent('open-cart-drawer'));
            } else {
              alert(result.data && result.data.description ? result.data.description : 'Could not add to cart.');
            }
          }).catch(function() { alert('Could not add to cart.'); }).then(function() {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = originalText;
            }
          });
        }, true);
      })();
    </script>
    {%- comment -%} Product page: thumbnail gallery + zoom lightbox (inline so it always runs after DOM) {%- endcomment -%}
    {% if request.page_type == 'product' %}
    <style>
      #product-image-lightbox {
        position: fixed;
        inset: 0;
        inset: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
        z-index: 9999;
        background: rgba(0, 0, 0, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        box-sizing: border-box;
      }
      #product-image-lightbox .product-lightbox-inner {
        max-width: 90vw;
        max-height: 90vh;
        max-height: 90dvh;
        position: relative;
      }
      #product-image-lightbox .product-lightbox-img {
        max-width: 100%;
        max-height: 90vh;
        max-height: 90dvh;
        width: auto;
        height: auto;
        object-fit: contain;
      }
      #product-image-lightbox .product-lightbox-close {
        position: absolute;
        top: max(16px, env(safe-area-inset-top));
        right: max(16px, env(safe-area-inset-right));
        width: 48px;
        height: 48px;
        border: none;
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
        font-size: 24px;
        line-height: 1;
        cursor: pointer;
        border-radius: 50%;
        z-index: 10;
        transition: background 0.2s;
      }
      #product-image-lightbox .product-lightbox-close:hover {
        background: rgba(255, 255, 255, 0.35);
      }
    </style>
    <script>
      (function() {
        function openLightbox(src, alt) {
          if (document.getElementById('product-image-lightbox')) return;
          var overlay = document.createElement('div');
          overlay.id = 'product-image-lightbox';
          overlay.setAttribute('role', 'dialog');
          overlay.setAttribute('aria-modal', 'true');
          overlay.setAttribute('aria-label', 'Zoomed product image');
          overlay.innerHTML = '<button type="button" class="product-lightbox-close" aria-label="Close">&times;</button><div class="product-lightbox-inner"><img src="" alt="" class="product-lightbox-img"></div>';
          var im = overlay.querySelector('.product-lightbox-img');
          im.src = src;
          im.alt = alt;
          document.body.appendChild(overlay);
          if (window.lockBodyScroll) window.lockBodyScroll();
          else document.body.style.overflow = 'hidden';
          function closeLightbox() {
            if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
            if (window.unlockBodyScroll) window.unlockBodyScroll();
            else document.body.style.overflow = '';
            document.removeEventListener('keydown', onKey);
          }
          function onKey(ev) {
            if (ev.key === 'Escape') closeLightbox();
          }
          overlay.addEventListener('click', function(ev) {
            if (ev.target === overlay || ev.target.classList.contains('product-lightbox-close')) closeLightbox();
          });
          document.addEventListener('keydown', onKey);
        }
        document.addEventListener('product-zoom-image', function(e) {
          if (e.detail && e.detail.src) openLightbox(e.detail.src, e.detail.alt || '');
        });
      })();
    </script>
    {% endif %}
  </body>
</html>
