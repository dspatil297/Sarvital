{% if customer %}
  <script>
    (function() {
      // Check if user just completed OAuth login
      const urlParams = new URLSearchParams(window.location.search);
      const hasLoginParams = urlParams.has('new_login') || 
                            urlParams.has('logged_in') || 
                            urlParams.has('locale') ||
                            document.referrer.includes('authentication/social/google');
      
      // Only redirect once per session
      const hasRedirected = sessionStorage.getItem('oauth_redirected');
      
      if (hasLoginParams && !hasRedirected) {
        sessionStorage.setItem('oauth_redirected', 'true');
        window.location.href = 'https://sarvital.com/';
      }
    })();
  </script>
{% endif %}

{% comment %}
  Customer Account Template
  This template is used for Classic customer accounts.
  For New Customer Accounts (hosted on account.sarvital.com), 
  this template may not be used - redirects must be handled differently.
{% endcomment %}

<section class="account-section">
  <div class="account-container">
    <h1 class="account-title">{{ 'customer.account.title' | t | default: 'My Account' }}</h1>
    
    <div class="account-content">
      <p>{{ 'customer.account.welcome' | t | default: 'Welcome back, ' }}{{ customer.first_name }}!</p>
      
      <div class="account-links">
        <a href="{{ routes.account_url }}/orders" class="account-link">
          {{ 'customer.account.orders' | t | default: 'Order History' }}
        </a>
        <a href="{{ routes.account_url }}/addresses" class="account-link">
          {{ 'customer.account.addresses' | t | default: 'Addresses' }}
        </a>
        <a href="{{ routes.account_logout_url }}" class="account-link">
          {{ 'customer.account.logout' | t | default: 'Logout' }}
        </a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .account-section {
    width: 100%;
    max-width: 100%;
    padding: var(--spacing-2xl) var(--container-padding);
    background: var(--white);
    box-sizing: border-box;
  }

  .account-container {
    max-width: var(--container-max-width);
    margin: 0 auto;
  }

  .account-title {
    font-family: var(--font-heading);
    font-size: clamp(var(--h2-size), 3vw, 36px);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--spacing-xl);
  }

  .account-content {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-sm);
  }

  .account-links {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .account-link {
    display: inline-block;
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--forest-green);
    color: var(--white);
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    transition: background 0.3s ease;
  }

  .account-link:hover {
    background: var(--sage-green);
  }

  @media (max-width: 768px) {
    .account-section {
      padding: var(--spacing-xl) var(--spacing-md);
    }

    .account-content {
      padding: var(--spacing-lg);
    }
  }
{% endstylesheet %}
