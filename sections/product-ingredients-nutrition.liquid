
{% comment %}
  Product Nutrition Facts Section
  Displays nutrition facts in a table format with columns: Nutrient, Per 100 g, % RDA per Serve
  Uses custom.nutrition_facts metafield
{% endcomment %}

<section class="product-ingredients-nutrition" id="product-ingredients-nutrition">
  <div class="product-ingredients-nutrition__container">
    
    <!-- Nutrition Facts Section -->
    {% assign nutrition_value = product.metafields.custom.nutrition_facts %}
    {% assign has_nutrition = false %}
    {% if nutrition_value != blank %}
      {% assign has_nutrition = true %}
    {% endif %}
    
    <div class="pdp-nutrition-shell">
      <button
        type="button"
        class="pdp-nutrition-shell__toggle"
        id="pdp-nutrition-toggle"
        aria-expanded="false"
        aria-controls="pdp-nutrition-panel"
      >
        <span class="pdp-nutrition-shell__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 9H4a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V11a2 2 0 0 0-2-2h-2"/>
            <rect x="6" y="1" width="12" height="8" rx="1" ry="1"/>
            <path d="M8 13h8M8 17h8M8 21h4"/>
          </svg>
        </span>
        <span class="pdp-nutrition-shell__copy">
          <span class="pdp-nutrition-shell__eyebrow">Nutrition clarity</span>
          <span class="pdp-nutrition-shell__title">Nutrition facts panel</span>
          <span class="pdp-nutrition-shell__subtitle">Fast scan values per 100 g and % RDA per serve.</span>
        </span>
        <span class="pdp-nutrition-shell__action" aria-hidden="true">View nutrition</span>
      </button>

      <div
        class="pdp-nutrition-shell__panel"
        id="pdp-nutrition-panel"
        role="region"
        aria-labelledby="pdp-nutrition-toggle"
        hidden
      >
        <div class="pdp-nutrition-table-wrapper">
        <table class="nutrition-table" 
               data-nutrition="{{ nutrition_value | escape }}"
               {% if nutrition_value %}data-nutrition-json="{{ nutrition_value | json | escape }}"{% endif %}>
          <thead>
            <tr>
              <th>Nutrient</th>
              <th>Per 100 g</th>
              <th>% RDA per Serve</th>
            </tr>
          </thead>
          <tbody>
            {% if has_nutrition %}
              {% comment %} Parse nutrition data - list metafield where each item is a row {% endcomment %}
              {% assign nutrition_list = nutrition_value.value | default: nutrition_value %}
              {% assign rows_parsed = false %}
              
              {% comment %} Handle list metafield - each item is a row {% endcomment %}
              {% if nutrition_list.first %}
                {% for row_item in nutrition_list %}
                  {% assign row_str = row_item | strip %}
                  {% if row_str != blank %}
                    {% comment %} Skip header rows {% endcomment %}
                    {% unless row_str == 'Nutrient' or row_str == 'Per 100 g' or row_str == '% RDA per Serve' or row_str == 'NUTRIENT' or row_str == 'PER 100 G' or row_str == '% RDA PER SERVE' or row_str contains 'Nutrient' and row_str contains 'Per 100' %}
                      {% assign parts = null %}
                      {% assign found_separator = false %}
                      
                      {% comment %} Try comma separator first {% endcomment %}
                      {% if row_str contains ',' %}
                        {% assign comma_test = row_str | split: ',' %}
                        {% if comma_test.size >= 3 %}
                          {% assign parts = comma_test %}
                          {% assign found_separator = true %}
                        {% endif %}
                      {% endif %}
                      
                      {% comment %} Try tab separator (actual tab character) {% endcomment %}
                      {% unless found_separator %}
                        {% assign tab_test = row_str | split: '	' %}
                        {% if tab_test.size >= 3 %}
                          {% assign parts = tab_test %}
                          {% assign found_separator = true %}
                        {% endif %}
                      {% endunless %}
                      
                      {% comment %} Try pipe separator {% endcomment %}
                      {% unless found_separator %}
                        {% if row_str contains '|' %}
                          {% assign pipe_test = row_str | split: '|' %}
                          {% if pipe_test.size >= 3 %}
                            {% assign parts = pipe_test %}
                            {% assign found_separator = true %}
                          {% endif %}
                        {% endif %}
                      {% endunless %}
                      
                      {% comment %} Try multiple spaces (2 or more) as separator {% endcomment %}
                      {% unless found_separator %}
                        {% if row_str contains '  ' %}
                          {% comment %} Split by 2+ spaces, but keep single spaces within values {% endcomment %}
                          {% assign space_parts = row_str | split: '  ' %}
                          {% if space_parts.size >= 3 %}
                            {% assign parts = space_parts %}
                            {% assign found_separator = true %}
                          {% endif %}
                        {% endif %}
                      {% endunless %}
                      
                      {% comment %} If no standard separator found, pass to JavaScript for smart parsing {% endcomment %}
                      {% unless found_separator %}
                        {% comment %} Mark this row for JavaScript parsing by adding a data attribute {% endcomment %}
                        {% assign needs_js_parse = true %}
                      {% endunless %}
                      
                      {% comment %} If we found parts, render the row {% endcomment %}
                      {% if found_separator and parts.size >= 3 %}
                        <tr>
                          <td>{{ parts[0] | strip }}</td>
                          <td>{{ parts[1] | strip }}</td>
                          <td>{{ parts[2] | strip }}</td>
                        </tr>
                        {% assign rows_parsed = true %}
                      {% elsif row_str != blank %}
                        {% comment %} If no separator found but item exists, try to parse as single value or show as-is in first column {% endcomment %}
                        {% comment %} This handles cases where the list item might be just the nutrient name {% endcomment %}
                        <tr>
                          <td>{{ row_str }}</td>
                          <td>—</td>
                          <td>—</td>
                        </tr>
                        {% assign rows_parsed = true %}
                      {% endif %}
                    {% endunless %}
                  {% endif %}
                {% endfor %}
              {% endif %}
              
              {% comment %} If still no rows parsed, show placeholder {% endcomment %}
              {% unless rows_parsed %}
                {% comment %} Show placeholder data {% endcomment %}
                <tr>
                  <td>Energy</td>
                  <td>325 kcal</td>
                  <td>0.81%</td>
                </tr>
                <tr>
                  <td>Protein</td>
                  <td>17.4 g</td>
                  <td>1.74%</td>
                </tr>
                <tr>
                  <td>Carbohydrate</td>
                  <td>60.9 g</td>
                  <td>1.17%</td>
                </tr>
              {% endunless %}
            {% else %}
              {% comment %} Show placeholder table when no nutrition metafield is set {% endcomment %}
              <tr>
                <td>Energy</td>
                <td>325 kcal</td>
                <td>0.81%</td>
              </tr>
              <tr>
                <td>Protein</td>
                <td>17.4 g</td>
                <td>1.74%</td>
              </tr>
              <tr>
                <td>Carbohydrate</td>
                <td>60.9 g</td>
                <td>1.17%</td>
              </tr>
            {% endif %}
          </tbody>
        </table>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  ;(function() {
    'use strict';
    var nutritionToggle = document.getElementById('pdp-nutrition-toggle');
    var nutritionPanel = document.getElementById('pdp-nutrition-panel');
    if (nutritionToggle && nutritionPanel) {
      var nutritionAction = nutritionToggle.querySelector('.pdp-nutrition-shell__action');
      function setNutritionExpanded(expanded) {
        nutritionToggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        nutritionPanel.hidden = !expanded;
        if (nutritionAction) nutritionAction.textContent = expanded ? 'Hide nutrition' : 'View nutrition';
      }
      setNutritionExpanded(nutritionToggle.getAttribute('aria-expanded') === 'true');
      nutritionToggle.addEventListener('click', function() {
        var expanded = nutritionToggle.getAttribute('aria-expanded') === 'true';
        setNutritionExpanded(!expanded);
      });
    }

    var nutritionTable = document.querySelector('.nutrition-table tbody');
    var tableElement = document.querySelector('.nutrition-table');
    
    var hasOnlyPlaceholders = nutritionTable && nutritionTable.children.length > 0 &&
      nutritionTable.children[0].textContent.indexOf('Energy') !== -1 &&
      nutritionTable.children.length <= 3;
    
    var needsReparse = false;
    if (nutritionTable && nutritionTable.children.length > 0) {
      var firstRow = nutritionTable.children[0];
      var cells = firstRow.querySelectorAll('td');
      if (cells.length >= 3) {
        var firstCell = cells[0].textContent.trim();
        var secondCell = cells[1].textContent.trim();
        var thirdCell = cells[2].textContent.trim();
        
        // If first cell has multiple words/numbers and other cells are "—" or empty, needs reparse
        if (firstCell && (secondCell === '—' || secondCell === '' || secondCell === '–') && 
            (thirdCell === '—' || thirdCell === '' || thirdCell === '–')) {
          // Check if first cell contains what looks like all three values (has numbers and %)
          if (firstCell.match(/\d/) && (firstCell.indexOf('%') !== -1 || firstCell.match(/\d+\s*(g|mg|kcal)/i))) {
            needsReparse = true;
          }
        }
      }
    }
    
      if (nutritionTable && tableElement && (nutritionTable.children.length === 0 || hasOnlyPlaceholders || needsReparse)) {
      var nutritionData = null;
      
      if (needsReparse) {
        var existingRows = Array.prototype.slice.call(nutritionTable.querySelectorAll('tr'));
        var rowData = existingRows.map(function(row) {
          var firstCell = row.querySelector('td:first-child');
          return firstCell ? firstCell.textContent.trim() : '';
        }).filter(function(text) { return text && text !== 'Nutrient' && text !== 'NUTRIENT'; });
        
        // Use extracted data if available
        if (rowData.length > 0) {
          nutritionData = rowData;
        }
        nutritionTable.innerHTML = '';
      }
      
      if (!nutritionData) {
        var nutritionRaw = tableElement.getAttribute('data-nutrition-json');
        
        if (nutritionRaw && nutritionRaw !== 'null' && nutritionRaw !== '') {
        try {
          nutritionData = JSON.parse(nutritionRaw);
        } catch (e) {
          // Try regular data attribute
          nutritionRaw = tableElement.getAttribute('data-nutrition');
          if (nutritionRaw && nutritionRaw !== 'null' && nutritionRaw !== '') {
            try {
              nutritionData = JSON.parse(nutritionRaw);
            } catch (e2) {
              nutritionData = nutritionRaw;
            }
          }
        }
      } else {
        // Fallback to regular data attribute
        nutritionRaw = tableElement.getAttribute('data-nutrition');
        if (nutritionRaw && nutritionRaw !== 'null' && nutritionRaw !== '') {
          try {
            nutritionData = JSON.parse(nutritionRaw);
          } catch (e) {
            nutritionData = nutritionRaw;
          }
        }
      }
      }
      
      if (nutritionData) {
        try {
          var rows = [];
          
          if (Array.isArray(nutritionData)) {
            rows = nutritionData.map(function(item) {
              if (typeof item === 'object' && item !== null && !Array.isArray(item)) {
                return item;
              }
              if (typeof item === 'string') {
                var cleanItem = item.trim();
                if (cleanItem.match(/^(nutrient|per\s*100|rda)/i)) {
                  return null;
                }
                var parts = cleanItem.split(',');
                if (parts.length >= 3) {
                  return {
                    nutrient: parts[0].trim(),
                    per_100g: parts[1].trim(),
                    rda: parts[2].trim()
                  };
                }
                
                // Try tab separator
                if (parts.length < 3) {
                  parts = cleanItem.split('\t');
                  if (parts.length >= 3) {
                    return {
                      nutrient: parts[0].trim(),
                      per_100g: parts[1].trim(),
                      rda: parts[2].trim()
                    };
                  }
                }
                
                // Try pipe separator
                if (parts.length < 3) {
                  parts = cleanItem.split('|');
                  if (parts.length >= 3) {
                    return {
                      nutrient: parts[0].trim(),
                      per_100g: parts[1].trim(),
                      rda: parts[2].trim()
                    };
                  }
                }
                
                // Try multiple spaces (2 or more)
                if (parts.length < 3) {
                  parts = cleanItem.split(/\s{2,}/);
                  if (parts.length >= 3) {
                    return {
                      nutrient: parts[0].trim(),
                      per_100g: parts[1].trim(),
                      rda: parts[2].trim()
                    };
                  }
                }
                
                if (parts.length < 3) {
                  var allParts = cleanItem.split(/\s+/);
                  var percentIndex = -1;
                  for (var i = allParts.length - 1; i >= 0; i--) {
                    if (allParts[i].indexOf('%') !== -1) {
                      percentIndex = i;
                      break;
                    }
                  }
                  if (percentIndex > 0) {
                    var percentage = allParts[percentIndex];
                    var valueUnit = '';
                    var nutrientEnd = percentIndex - 1;
                    if (percentIndex > 0) {
                      var beforePercent = allParts[percentIndex - 1];
                      var unitMatch = beforePercent.match(/^(g|mg|kcal)$/i);
                      if (unitMatch && percentIndex > 1) {
                        valueUnit = allParts[percentIndex - 2] + ' ' + allParts[percentIndex - 1];
                        nutrientEnd = percentIndex - 3;
                      } else {
                        valueUnit = allParts[percentIndex - 1];
                        nutrientEnd = percentIndex - 2;
                      }
                    }
                    var nutrientName = allParts.slice(0, nutrientEnd + 1).join(' ');
                    if (nutrientName && valueUnit && percentage) {
                      return {
                        nutrient: nutrientName.trim(),
                        per_100g: valueUnit.trim(),
                        rda: percentage.trim()
                      };
                    }
                  }
                }
                return {
                  nutrient: cleanItem,
                  per_100g: '',
                  rda: ''
                };
              }
              if (Array.isArray(item) && item.length >= 3) {
                return {
                  nutrient: item[0],
                  per_100g: item[1],
                  rda: item[2]
                };
              }
              return null;
            }).filter(function(row) { return row !== null; });
          } else if (nutritionData && typeof nutritionData === 'object' && nutritionData.value) {
            if (Array.isArray(nutritionData.value)) {
              rows = nutritionData.value.map(function(item) {
                if (typeof item === 'string') {
                  var cleanItem = item.trim();
                  if (cleanItem.match(/^(nutrient|per\s*100|rda)/i)) {
                    return null;
                  }
                  var parts = cleanItem.split(',');
                  if (parts.length >= 3) {
                    return {
                      nutrient: parts[0].trim(),
                      per_100g: parts[1].trim(),
                      rda: parts[2].trim()
                    };
                  }
                  if (parts.length < 3) parts = cleanItem.split('\t');
                  if (parts.length >= 3) {
                    return {
                      nutrient: parts[0].trim(),
                      per_100g: parts[1].trim(),
                      rda: parts[2].trim()
                    };
                  }
                  if (parts.length < 3) parts = cleanItem.split('|');
                  if (parts.length >= 3) {
                    return {
                      nutrient: parts[0].trim(),
                      per_100g: parts[1].trim(),
                      rda: parts[2].trim()
                    };
                  }
                  if (parts.length < 3) parts = cleanItem.split(/\s{2,}/);
                  if (parts.length >= 3) {
                    return {
                      nutrient: parts[0].trim(),
                      per_100g: parts[1].trim(),
                      rda: parts[2].trim()
                    };
                  }
                  var allParts = cleanItem.split(/\s+/);
                  var percentIndex = -1;
                  for (var i = allParts.length - 1; i >= 0; i--) {
                    if (allParts[i].indexOf('%') !== -1) {
                      percentIndex = i;
                      break;
                    }
                  }
                  if (percentIndex > 0) {
                    var percentage = allParts[percentIndex];
                    var valueUnit = '';
                    var nutrientEnd = percentIndex - 1;
                    if (percentIndex > 0) {
                      var beforePercent = allParts[percentIndex - 1];
                      var unitMatch = beforePercent.match(/^(g|mg|kcal)$/i);
                      if (unitMatch && percentIndex > 1) {
                        valueUnit = allParts[percentIndex - 2] + ' ' + allParts[percentIndex - 1];
                        nutrientEnd = percentIndex - 3;
                      } else {
                        valueUnit = allParts[percentIndex - 1];
                        nutrientEnd = percentIndex - 2;
                      }
                    }
                    var nutrientName = allParts.slice(0, nutrientEnd + 1).join(' ');
                    if (nutrientName && valueUnit && percentage) {
                      return {
                        nutrient: nutrientName.trim(),
                        per_100g: valueUnit.trim(),
                        rda: percentage.trim()
                      };
                    }
                  }
                  return { nutrient: cleanItem, per_100g: '', rda: '' };
                }
                return item;
              }).filter(function(row) { return row !== null; });
            } else {
              nutritionData = nutritionData.value;
            }
          }
          
          if (!Array.isArray(rows) && typeof nutritionData === 'string') {
            var lines = nutritionData.split(/\r?\n/).filter(function(line) { return line.trim(); });
            rows = lines.map(function(line) {
              var cleanLine = line.trim();
              if (cleanLine.match(/^(nutrient|per\s*100|rda)/i)) {
                return null;
              }
              var parts = cleanLine.split(',');
              if (parts.length >= 3) {
                return {
                  nutrient: parts[0].trim(),
                  per_100g: parts[1].trim(),
                  rda: parts[2].trim()
                };
              }
              
              // Try tab separator
              if (parts.length < 3) parts = cleanLine.split('\t');
              if (parts.length >= 3) {
                return {
                  nutrient: parts[0].trim(),
                  per_100g: parts[1].trim(),
                  rda: parts[2].trim()
                };
              }
              
              // Try pipe separator
              if (parts.length < 3) parts = cleanLine.split('|');
              if (parts.length >= 3) {
                return {
                  nutrient: parts[0].trim(),
                  per_100g: parts[1].trim(),
                  rda: parts[2].trim()
                };
              }
              
              // Try multiple spaces
              if (parts.length < 3) parts = cleanLine.split(/\s{2,}/);
              if (parts.length >= 3) {
                return {
                  nutrient: parts[0].trim(),
                  per_100g: parts[1].trim(),
                  rda: parts[2].trim()
                };
              }
              
              var allParts = cleanLine.split(/\s+/);
              var percentIndex = -1;
              for (var i = allParts.length - 1; i >= 0; i--) {
                if (allParts[i].indexOf('%') !== -1) {
                  percentIndex = i;
                  break;
                }
              }
              if (percentIndex > 0) {
                var percentage = allParts[percentIndex];
                var valueUnit = '';
                var nutrientEnd = percentIndex - 1;
                if (percentIndex > 0) {
                  var beforePercent = allParts[percentIndex - 1];
                  var unitMatch = beforePercent.match(/^(g|mg|kcal)$/i);
                  if (unitMatch && percentIndex > 1) {
                    valueUnit = allParts[percentIndex - 2] + ' ' + allParts[percentIndex - 1];
                    nutrientEnd = percentIndex - 3;
                  } else {
                    valueUnit = allParts[percentIndex - 1];
                    nutrientEnd = percentIndex - 2;
                  }
                }
                var nutrientName = allParts.slice(0, nutrientEnd + 1).join(' ');
                if (nutrientName && valueUnit && percentage) {
                  return {
                    nutrient: nutrientName.trim(),
                    per_100g: valueUnit.trim(),
                    rda: percentage.trim()
                  };
                }
              }
              return null;
            }).filter(function(row) { return row !== null; });
          }
          if (Array.isArray(rows) && rows.length > 0) {
            if (hasOnlyPlaceholders) {
              nutritionTable.innerHTML = '';
            }
            rows.forEach(function(row) {
              var nutrient = row.nutrient || row.name || (Array.isArray(row) ? row[0] : '');
              var per100g = row.per_100g || row.per100g || row.per_100_g || (Array.isArray(row) ? row[1] : '');
              var rda = row.rda_per_serve || row.rda || (Array.isArray(row) ? row[2] : '');
              if (nutrient && typeof nutrient === 'string' && !nutrient.match(/^(nutrient|per\s*100|rda)/i)) {
                var tr = document.createElement('tr');
                tr.innerHTML = '<td>' + nutrient + '</td><td>' + (per100g || '—') + '</td><td>' + (rda || '—') + '</td>';
                nutritionTable.appendChild(tr);
              }
            });
          }
        } catch (error) {
          console.error('Error parsing nutrition data:', error);
        }
      }
    }
  })();
</script>

{% stylesheet %}
  .product-ingredients-nutrition {
    width: 100%;
    max-width: 100%;
    padding: 50px 40px;
    background: linear-gradient(135deg, rgba(45, 80, 22, 0.03) 0%, rgba(74, 124, 44, 0.05) 50%, rgba(255, 255, 255, 0.02) 100%);
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  .product-ingredients-nutrition::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--forest-green), var(--sage-green), var(--white));
    opacity: 0.3;
  }

  .product-ingredients-nutrition__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .pdp-nutrition-shell {
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.95), rgba(74, 124, 44, 0.06));
    border: 1px solid rgba(45, 80, 22, 0.14);
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(45, 80, 22, 0.08);
    overflow: hidden;
  }

  .pdp-nutrition-shell__toggle {
    width: 100%;
    border: 0;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    text-align: left;
    border-bottom: 1px solid rgba(26, 26, 26, 0.08);
  }

  .pdp-nutrition-shell__toggle:focus-visible {
    outline: 2px solid var(--forest-green);
    outline-offset: -2px;
  }

  .pdp-nutrition-shell__icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--forest-green);
    background: rgba(74, 124, 44, 0.14);
    flex-shrink: 0;
  }

  .pdp-nutrition-shell__copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1;
  }

  .pdp-nutrition-shell__eyebrow {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: rgba(45, 80, 22, 0.72);
  }

  .pdp-nutrition-shell__title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
  }

  .pdp-nutrition-shell__subtitle {
    font-size: 13px;
    line-height: 1.45;
    color: rgba(26, 26, 26, 0.62);
  }

  .pdp-nutrition-shell__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(74, 124, 44, 0.14);
    color: var(--forest-green);
    font-size: 13px;
    line-height: 1;
    font-weight: 700;
    flex-shrink: 0;
  }

  .pdp-nutrition-shell__toggle[aria-expanded='true'] .pdp-nutrition-shell__action {
    background: rgba(45, 80, 22, 0.2);
  }

  .pdp-nutrition-shell__panel {
    padding: 16px 20px 20px;
  }

  .pdp-nutrition-shell__panel[hidden] {
    display: none !important;
    padding: 0;
    border: 0;
  }

  .pdp-nutrition-table-wrapper {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid rgba(26, 26, 26, 0.08);
    background: var(--white);
  }

  .nutrition-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(250, 250, 250, 0.9) 100%);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 
      0 4px 16px rgba(45, 80, 22, 0.08),
      0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .nutrition-table thead {
    background: var(--forest-green);
  }

  .nutrition-table th {
    padding: 18px 24px;
    text-align: left;
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
    color: var(--white);
    text-transform: none;
    letter-spacing: 0.01em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }

  .nutrition-table th:first-child {
    border-top-left-radius: 12px;
  }

  .nutrition-table th:last-child {
    border-top-right-radius: 12px;
    text-align: right;
  }

  .nutrition-table th:nth-child(2) {
    text-align: center;
  }

  .nutrition-table tbody tr {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-bottom: 1px solid rgba(74, 124, 44, 0.1);
  }

  .nutrition-table tbody tr:last-child {
    border-bottom: none;
  }

  .nutrition-table tbody tr:hover {
    background: linear-gradient(135deg, rgba(255, 255, 255, 1) 0%, rgba(250, 250, 250, 0.95) 100%);
    box-shadow: inset 0 0 0 2px rgba(74, 124, 44, 0.15);
  }

  .nutrition-table td {
    padding: 16px 24px;
    font-size: 16px;
    line-height: 1.6;
    color: rgba(26, 26, 26, 0.9);
    font-weight: 500;
  }

  .nutrition-table td:first-child {
    font-weight: 600;
    color: var(--forest-green);
  }

  .nutrition-table td:last-child {
    text-align: right;
    font-weight: 600;
  }

  .nutrition-table td:nth-child(2) {
    text-align: center;
  }

  /* Responsive Design */
  @media (max-width: 968px) {
    .product-ingredients-nutrition {
      padding: 40px 20px;
    }

    .pdp-nutrition-shell__toggle {
      padding: 16px;
    }

    .pdp-nutrition-shell__title {
      font-size: 20px;
    }

    .pdp-nutrition-shell__panel {
      padding: 14px 16px 16px;
    }

    .nutrition-table th,
    .nutrition-table td {
      padding: 14px 20px;
      font-size: 15px;
    }
  }

  @media (max-width: 768px) {
    .product-ingredients-nutrition {
      padding: 30px 16px;
    }

    .pdp-nutrition-shell {
      border-radius: 14px;
    }

    .pdp-nutrition-shell__toggle {
      padding: 14px;
      gap: 10px;
    }

    .pdp-nutrition-shell__icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
    }

    .pdp-nutrition-shell__title {
      font-size: 18px;
    }

    .pdp-nutrition-shell__subtitle {
      font-size: 12px;
    }

    .pdp-nutrition-shell__panel {
      padding: 12px 14px 14px;
    }

    .nutrition-table th,
    .nutrition-table td {
      padding: 12px 16px;
      font-size: 14px;
    }

    .nutrition-table th {
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    .product-ingredients-nutrition {
      padding: 24px 16px;
    }

    .pdp-nutrition-table-wrapper {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .nutrition-table {
      min-width: 500px;
    }

    .nutrition-table th,
    .nutrition-table td {
      padding: 10px 12px;
      font-size: 13px;
    }

    .nutrition-table th {
      font-size: 12px;
      padding: 12px 14px;
    }
  }
{% endstylesheet %}

