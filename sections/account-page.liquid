{% comment %}
  Account Page Section - Customer account dashboard with orders and address.
  Uses theme layout (theme.liquid) so global header and footer are visible.
{% endcomment %}

{%- style -%}
  .account-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (min-width: 750px) {
    .account-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 1.2 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 1.2 | round: 0 }}px;
    }
  }
{%- endstyle -%}

<div class="account-page account-section-{{ section.id }}">
  <div class="account-page__container">
    {%- comment -%} Page header: title + logout {%- endcomment -%}
    <header class="account-page__header">
      <h1 class="account-page__title">
        {{ 'customers.account.title' | t | default: 'My Account' }}
      </h1>
      <a href="{{ routes.account_logout_url }}" class="account-page__logout">
        {{ 'customers.account.log_out' | t | default: 'Log out' }}
      </a>
    </header>

    <div class="account-page__grid">
      {%- comment -%} Orders block {%- endcomment -%}
      <div class="account-page__block account-orders">
        <h2 class="account-page__block-title">
          {{ 'customers.orders.title' | t | default: 'Order history' }}
        </h2>

        {% paginate customer.orders by 20 %}
          {% if customer.orders.size > 0 %}
            <div class="account-orders__table-wrap">
              <table class="account-orders__table" role="table">
                <thead>
                  <tr>
                    <th scope="col">{{ 'customers.orders.order_number' | t | default: 'Order' }}</th>
                    <th scope="col">{{ 'customers.orders.date' | t | default: 'Date' }}</th>
                    <th scope="col">{{ 'customers.orders.payment_status' | t | default: 'Payment' }}</th>
                    <th scope="col">{{ 'customers.orders.fulfillment_status' | t | default: 'Fulfillment' }}</th>
                    <th scope="col" class="account-orders__total-col">{{ 'customers.orders.total' | t | default: 'Total' }}</th>
                    <th scope="col" class="account-orders__action-col"></th>
                  </tr>
                </thead>
                <tbody>
                  {% for order in customer.orders %}
                    <tr>
                      <td data-label="{{ 'customers.orders.order_number' | t | default: 'Order' }}">
                        <a href="{{ order.customer_url }}" class="account-orders__order-link">{{ order.name }}</a>
                      </td>
                      <td data-label="{{ 'customers.orders.date' | t | default: 'Date' }}">
                        {{ order.created_at | time_tag: format: 'date' }}
                      </td>
                      <td data-label="{{ 'customers.orders.payment_status' | t | default: 'Payment' }}">
                        <span class="account-orders__status account-orders__status--{{ order.financial_status | handle }}">
                          {{ order.financial_status_label }}
                        </span>
                      </td>
                      <td data-label="{{ 'customers.orders.fulfillment_status' | t | default: 'Fulfillment' }}">
                        <span class="account-orders__status account-orders__status--{{ order.fulfillment_status | handle }}">
                          {{ order.fulfillment_status_label }}
                        </span>
                      </td>
                      <td data-label="{{ 'customers.orders.total' | t | default: 'Total' }}" class="account-orders__total-col">
                        <strong>{{ order.total_price | money_with_currency }}</strong>
                      </td>
                      <td class="account-orders__action-col">
                        <a href="{{ order.customer_url }}" class="account-orders__view-btn">
                          {{ 'customers.orders.view_order' | t | default: 'View' }}
                        </a>
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>

            {% if paginate.pages > 1 %}
              <nav class="account-page__pagination" aria-label="Order history pagination">
                {% if paginate.previous %}
                  <a href="{{ paginate.previous.url }}" class="account-page__pagination-link account-page__pagination-link--prev" aria-label="Previous page">
                    &larr; {{ 'general.pagination.previous' | t | default: 'Previous' }}
                  </a>
                {% endif %}
                <span class="account-page__pagination-info">
                  {{ 'general.pagination.page' | t | default: 'Page' }} {{ paginate.current_page }} {{ 'general.pagination.of' | t | default: 'of' }} {{ paginate.pages }}
                </span>
                {% if paginate.next %}
                  <a href="{{ paginate.next.url }}" class="account-page__pagination-link account-page__pagination-link--next" aria-label="Next page">
                    {{ 'general.pagination.next' | t | default: 'Next' }} &rarr;
                  </a>
                {% endif %}
              </nav>
            {% endif %}
          {% else %}
            <div class="account-orders__empty">
              <p>{{ 'customers.orders.none' | t }}</p>
              <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">
                {{ 'customers.orders.start_shopping' | t | default: 'Start shopping' }}
              </a>
            </div>
          {% endif %}
        {% endpaginate %}
      </div>

      {%- comment -%} Address & details block {%- endcomment -%}
      <div class="account-page__block account-details">
        <h2 class="account-page__block-title">
          {{ 'customers.account.details' | t | default: 'Account details' }}
        </h2>
        <div class="account-details__card">
          {% if customer.default_address %}
            <div class="account-details__address">
              <p class="account-details__address-label">{{ 'customers.account.default_address' | t | default: 'Default address' }}</p>
              {{ customer.default_address | format_address }}
            </div>
          {% endif %}
          <a href="{{ routes.account_addresses_url }}" class="account-details__link">
            {{ 'customers.account.view_addresses' | t | default: 'View addresses' }} ({{ customer.addresses_count }})
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .account-page {
    width: 100%;
    max-width: 100%;
    min-height: 50vh;
    background: linear-gradient(180deg, var(--white) 0%, var(--bg) 30%, var(--white) 100%);
    box-sizing: border-box;
  }
  .account-page__container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
    width: 100%;
  }
  .account-page__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-2xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 2px solid rgba(74, 124, 44, 0.12);
  }
  .account-page__title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 900;
    color: var(--forest-green);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .account-page__logout {
    font-size: var(--body-normal);
    color: var(--sage-green);
    font-weight: 600;
    text-decoration: none;
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-md);
    border: 2px solid rgba(74, 124, 44, 0.2);
    background: var(--white);
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .account-page__logout:hover {
    color: var(--forest-green);
    border-color: var(--sage-green);
    background: rgba(74, 124, 44, 0.06);
  }
  .account-page__grid {
    display: grid;
    gap: var(--spacing-2xl);
  }
  @media screen and (min-width: 990px) {
    .account-page__grid {
      grid-template-columns: 1fr 360px;
      align-items: start;
    }
  }
  .account-page__block {
    background: var(--white);
    border-radius: var(--radius-xl);
    box-shadow: 0 10px 40px rgba(45, 80, 22, 0.08);
    border: 1px solid rgba(74, 124, 44, 0.12);
    padding: var(--spacing-xl);
    box-sizing: border-box;
  }
  .account-page__block-title {
    font-family: var(--font-heading);
    font-size: var(--h4-size);
    font-weight: 700;
    color: var(--forest-green);
    margin: 0 0 var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--border-color);
  }
  /* Orders table */
  .account-orders__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 0 calc(-1 * var(--spacing-md));
    padding: 0 var(--spacing-md);
  }
  .account-orders__table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    font-size: var(--body-small);
  }
  .account-orders__table thead {
    border-bottom: 2px solid rgba(74, 124, 44, 0.15);
  }
  .account-orders__table th {
    text-align: left;
    padding: var(--spacing-md) var(--spacing-sm);
    font-weight: 600;
    color: var(--forest-green);
  }
  .account-orders__table td {
    padding: var(--spacing-md) var(--spacing-sm);
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
  }
  .account-orders__table tbody tr:last-child td {
    border-bottom: none;
  }
  .account-orders__table tbody tr:hover {
    background: rgba(74, 124, 44, 0.03);
  }
  .account-orders__order-link {
    color: var(--sage-green);
    font-weight: 600;
    text-decoration: none;
  }
  .account-orders__order-link:hover {
    text-decoration: underline;
    color: var(--forest-green);
  }
  .account-orders__status {
    display: inline-block;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    font-size: var(--body-xs);
    font-weight: 500;
  }
  .account-orders__status--paid,
  .account-orders__status--fulfilled {
    background: rgba(74, 124, 44, 0.12);
    color: var(--forest-green);
  }
  .account-orders__status--pending,
  .account-orders__status--unfulfilled {
    background: rgba(255, 193, 7, 0.2);
    color: #8b6914;
  }
  .account-orders__status--refunded,
  .account-orders__status--cancelled {
    background: rgba(0, 0, 0, 0.06);
    color: var(--text);
  }
  .account-orders__view-btn {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-md);
    font-size: var(--body-small);
    font-weight: 600;
    color: var(--forest-green);
    background: rgba(74, 124, 44, 0.1);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .account-orders__view-btn:hover {
    background: var(--sage-green);
    color: var(--white);
  }
  .account-orders__empty {
    text-align: center;
    padding: var(--spacing-2xl) var(--spacing-lg);
    color: var(--text);
  }
  .account-orders__empty p {
    margin: 0 0 var(--spacing-lg);
    font-size: var(--body-normal);
  }
  /* Pagination */
  .account-page__pagination {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--border-color);
  }
  .account-page__pagination-link {
    font-size: var(--body-small);
    font-weight: 600;
    color: var(--sage-green);
    text-decoration: none;
  }
  .account-page__pagination-link:hover {
    color: var(--forest-green);
    text-decoration: underline;
  }
  .account-page__pagination-info {
    font-size: var(--body-small);
    color: var(--text);
  }
  /* Details / address card */
  .account-details__card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }
  .account-details__address {
    font-size: var(--body-small);
    line-height: 1.6;
    color: var(--text);
  }
  .account-details__address-label {
    font-weight: 600;
    color: var(--forest-green);
    margin: 0 0 var(--spacing-xs);
  }
  .account-details__address p {
    margin: 0 0 var(--spacing-xs);
  }
  .account-details__link {
    font-size: var(--body-normal);
    font-weight: 600;
    color: var(--sage-green);
    text-decoration: none;
    margin-top: var(--spacing-sm);
  }
  .account-details__link:hover {
    text-decoration: underline;
    color: var(--forest-green);
  }
  /* Responsive: stack table as cards on small screens */
  @media screen and (max-width: 749px) {
    .account-orders__table thead {
      display: none;
    }
    .account-orders__table,
    .account-orders__table-wrap {
      min-width: 0;
      margin: 0;
      padding: 0;
    }
    .account-orders__table tr {
      display: block;
      padding: var(--spacing-md) 0;
      border-bottom: 1px solid var(--border-color);
    }
    .account-orders__table tr:last-child {
      border-bottom: none;
    }
    .account-orders__table td {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--spacing-sm);
      padding: var(--spacing-xs) 0;
      border-bottom: none;
    }
    .account-orders__table td::before {
      content: attr(data-label);
      font-weight: 600;
      color: var(--forest-green);
      flex-shrink: 0;
    }
    .account-orders__table td.account-orders__action-col::before {
      content: '';
    }
    .account-orders__table .account-orders__action-col {
      justify-content: flex-end;
      padding-top: var(--spacing-sm);
    }
  }
</style>

{% schema %}
{
  "name": "Account",
  "tag": "section",
  "class": "section-account",
  "settings": [
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ]
}
{% endschema %}
