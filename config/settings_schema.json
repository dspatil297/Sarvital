[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
 "name": "Gokwik",
 "settings": [
   {
     "type": "text",
     "id": "mid",
     "label": "Merchant Id"
   },
   {
     "type": "header",
     "content": "Select environment"
   },
   {
     "type": "select",
     "id": "envType",
     "options": [
       { "value": "qa", "label": "QA" },
       { "value": "sandbox", "label": "Sandbox" },
       { "value": "production", "label": "Production" }
     ]
   },
   {
     "type": "checkbox",
     "id": "hideFlow",
     "label": "Button hide without disable",
     "info": "To hide only button without disable Gokwik flow",
     "default": false
   },
   {
     "type": "header",
     "content": "Data Tracking"
   },
   {
     "type": "text",
     "id": "ga4Gokwik",
     "label": "Enter Google Analytics ID (GA4)",
     "placeholder": "Starts with GA- ...."
   },
   {
     "type": "text",
     "id": "fbpixel",
     "label": "FB Pixel"
   },
   {
     "type": "text",
     "id": "snapPixel",
     "label": "Snapchat Pixel"
   },
   {
     "type": "header",
     "content": "Checkout Button"
   },
   {
     "type": "checkbox",
     "id": "goEnable",
     "label": "Enable Checkout Button",
     "info": "To insert button use {% include 'gokwik-checkout'%}"
   },
   {
     "type": "color",
     "id": "priClr",
     "label": "Primary Color",
     "default": "#000000"
   },
   {
     "type": "color",
     "id": "secClr",
     "label": "Secondary Color",
     "default": "#ffffff"
   },
   {
     "type": "text",
     "id": "main-titile",
     "label": "Button Text",
     "default": "Checkout"
   },
   {
     "type": "header",
     "content": "Buy Now Button"
   },
   {
     "type": "checkbox",
     "id": "goBuynowEnable",
     "label": "Enable Buynow Button",
     "info": "To insert button use {% include 'gokwik-buy-now'%}"
   },
   {
     "type": "color",
     "id": "btnBClr",
     "label": "Background Color",
     "default": "#000000"
   },
   {
     "type": "color",
     "id": "btnTextClr",
     "label": "Text Color",
     "default": "#ffffff"
   },
   {
     "type": "text",
     "id": "buyNowText",
     "label": "Buy Now Button Text",
     "default": "Buy It Now"
   },
   {
     "type": "header",
     "content": "Other Settings"
   },
   {
     "type": "text",
     "id": "sub-titile",
     "label": "Button Sub Text"
   },
   {
     "type": "checkbox",
     "id": "enableLogo",
     "label": "Enable Logo"
   },
   {
     "type": "checkbox",
     "id": "enableIntlFlow",
     "label": "Enable International Flow"
   },
   {
     "type": "checkbox",
     "id": "enableBannertext",
     "label": "Enable Banner Text"
   }
 ]
}


]
