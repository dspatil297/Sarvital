<div class="cart-drawer" id="cart-drawer" data-cart-drawer>
  <div class="cart-drawer-overlay" data-cart-drawer-close></div>
  <div class="cart-drawer-content">
    <div class="cart-drawer-header">
      <h2 class="cart-drawer-title">Your Cart</h2>
      <button type="button" class="cart-drawer-close" data-cart-drawer-close aria-label="Close cart">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <div class="cart-drawer-body" data-cart-drawer-body>
      <div class="cart-drawer-loading" data-cart-loading>
        <div class="loading-spinner"></div>
        <p>Loading cart...</p>
      </div>

      <div class="cart-drawer-items" data-cart-items></div>

      <div class="cart-drawer-empty" data-cart-empty>
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 20H44L58 48H6L20 20Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="20" cy="56" r="4" fill="currentColor"/>
          <circle cx="52" cy="56" r="4" fill="currentColor"/>
        </svg>
        <h3>Your cart is empty</h3>
        <p>Add some products to get started!</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Continue Shopping</a>
      </div>
    </div>

    <div class="cart-drawer-footer" data-cart-footer>
      <div class="cart-drawer-totals">
        <div class="cart-total-row">
          <span>Subtotal</span>
          <span data-cart-subtotal></span>
        </div>
        <div class="cart-total-row cart-total-row--shipping">
          <span>Shipping</span>
          <span>Calculated at checkout</span>
        </div>
        <div class="cart-total-row cart-total-row--total">
          <span>Total</span>
          <span data-cart-total></span>
        </div>
      </div>
      <div class="cart-drawer-actions">
        <a href="{{ routes.cart_url }}" class="btn btn-outline">View Cart</a>
        <button type="button" class="btn btn-primary" data-cart-checkout>Checkout</button>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* Cart Drawer */
  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: var(--z-modal);
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-base);
  }

  .cart-drawer.active {
    opacity: 1;
    visibility: visible;
  }

  .cart-drawer-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
  }

  .cart-drawer-content {
    position: absolute;
    top: 0;
    right: 0;
    width: 90%;
    max-width: 420px;
    height: 100%;
    height: 100dvh;
    height: -webkit-fill-available;
    min-height: -webkit-fill-available;
    background-color: var(--white);
    box-shadow: var(--shadow-xl);
    transform: translateX(100%);
    transition: transform var(--transition-base);
    display: flex;
    flex-direction: column;
    padding-top: env(safe-area-inset-top);
    padding-right: env(safe-area-inset-right);
    padding-bottom: env(safe-area-inset-bottom);
  }

  .cart-drawer.active .cart-drawer-content {
    transform: translateX(0);
  }

  /* Cart Drawer Header */
  .cart-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-lg);
    border-bottom: 1px solid var(--border-color);
  }

  .cart-drawer-title {
    font-family: var(--font-heading);
    font-size: var(--h3-size);
    font-weight: 700;
    color: var(--forest-green);
    margin: 0;
  }

  .cart-drawer-close {
    background: none;
    border: none;
    color: var(--text);
    cursor: pointer;
    padding: var(--spacing-sm);
    transition: color var(--transition-base);
  }

  .cart-drawer-close:hover {
    color: var(--sage-green);
  }

  /* Cart Drawer Body */
  .cart-drawer-body {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: var(--spacing-lg);
  }

  .cart-drawer-loading {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-4xl) var(--spacing-lg);
    text-align: center;
  }

  .cart-drawer-loading.active {
    display: flex;
  }

  .loading-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--border-color);
    border-top-color: var(--sage-green);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-bottom: var(--spacing-md);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .cart-drawer-items {
    display: none;
  }

  .cart-drawer-items.active {
    display: block;
  }

  .cart-item {
    display: flex;
    gap: var(--spacing-md);
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--border-color);
  }

  .cart-item:last-child {
    border-bottom: none;
  }

  .cart-item-image {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: var(--bg);
  }

  .cart-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .cart-item-title {
    font-size: var(--body-normal);
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }

  .cart-item-title a {
    color: var(--text);
    text-decoration: none;
  }

  .cart-item-title a:hover {
    color: var(--sage-green);
  }

  .cart-item-variant {
    font-size: var(--body-small);
    color: #666;
  }

  .cart-item-price {
    font-size: var(--body-normal);
    font-weight: 600;
    color: var(--forest-green);
  }

  .cart-item-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-xs);
  }

  .cart-item-quantity {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-xs);
  }

  .cart-item-quantity button {
    background: none;
    border: none;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text);
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-fast);
  }

  .cart-item-quantity button:hover {
    background-color: var(--bg);
  }

  .cart-item-quantity__value {
    display: inline-block;
    min-width: 32px;
    width: 40px;
    text-align: center;
    font-size: var(--body-small);
    font-weight: 700;
    color: var(--text);
    line-height: 24px;
    height: 24px;
  }

  .cart-item-remove {
    background: none;
    border: none;
    color: #999;
    cursor: pointer;
    padding: var(--spacing-xs);
    font-size: var(--body-small);
    transition: color var(--transition-fast);
  }

  .cart-item-remove:hover {
    color: #ff6b6b;
  }

  /* Cart Drawer Empty */
  .cart-drawer-empty {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-4xl) var(--spacing-lg);
    text-align: center;
  }

  .cart-drawer-empty.active {
    display: flex;
  }

  .cart-drawer-empty svg {
    color: var(--border-color);
    margin-bottom: var(--spacing-lg);
  }

  .cart-drawer-empty h3 {
    font-size: var(--h4-size);
    color: var(--text);
    margin-bottom: var(--spacing-sm);
  }

  .cart-drawer-empty p {
    font-size: var(--body-normal);
    color: #666;
    margin-bottom: var(--spacing-lg);
  }

  /* Cart Drawer Footer */
  .cart-drawer-footer {
    padding: var(--spacing-lg);
    border-top: 1px solid var(--border-color);
    background-color: var(--bg);
  }

  .cart-drawer-totals {
    margin-bottom: var(--spacing-lg);
  }

  .cart-total-row {
    display: flex;
    justify-content: space-between;
    padding: var(--spacing-sm) 0;
    font-size: var(--body-normal);
    color: var(--text);
  }

  .cart-total-row--shipping {
    font-size: var(--body-small);
    color: #666;
  }

  .cart-total-row--total {
    font-size: var(--h5-size);
    font-weight: 700;
    color: var(--forest-green);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--border-color);
  }

  .cart-drawer-actions {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .cart-drawer-actions .btn {
    width: 100%;
    justify-content: center;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .cart-drawer-content {
      width: 100%;
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
  ;(function() {
    'use strict';

    function initCartDrawer() {
      var cartDrawer = document.getElementById('cart-drawer');
      if (!cartDrawer) return;

      var cartDrawerClose = document.querySelectorAll('[data-cart-drawer-close]');
      var cartDrawerBody = document.querySelector('[data-cart-drawer-body]');
      var cartItems = document.querySelector('[data-cart-items]');
      var cartEmpty = document.querySelector('[data-cart-empty]');
      var cartLoading = document.querySelector('[data-cart-loading]');
      var cartFooter = document.querySelector('[data-cart-footer]');
      var cartSubtotal = document.querySelector('[data-cart-subtotal]');
      var cartTotal = document.querySelector('[data-cart-total]');
      var cartCheckout = document.querySelector('[data-cart-checkout]');
      var cartToggle = document.querySelector('[data-cart-toggle]');

    // Open cart drawer: show UI immediately so page doesn't freeze, then load cart in next frame
    function openCartDrawer() {
      cartDrawer.classList.add('active');
      if (window.lockBodyScroll) window.lockBodyScroll();
      else document.body.style.overflow = 'hidden';
      if (cartLoading) cartLoading.classList.add('active');
      if (cartItems) cartItems.classList.remove('active');
      if (cartEmpty) cartEmpty.classList.remove('active');
      if (cartFooter) cartFooter.style.display = 'none';
      if (typeof requestAnimationFrame !== 'undefined') {
        requestAnimationFrame(function() { loadCart(); });
      } else {
        setTimeout(function() { loadCart(); }, 0);
      }
    }

    // Close cart drawer
    function closeCartDrawer() {
      cartDrawer.classList.remove('active');
      if (window.unlockBodyScroll) window.unlockBodyScroll();
      else document.body.style.overflow = '';
    }

    // Load cart data
    function loadCart() {
      cartLoading.classList.add('active');
      cartItems.classList.remove('active');
      cartEmpty.classList.remove('active');
      cartFooter.style.display = 'none';

      fetch('/cart.js')
        .then(function(response) { return response.json(); })
        .then(function(cart) {
          cartLoading.classList.remove('active');
          if (typeof requestAnimationFrame !== 'undefined') {
            requestAnimationFrame(function() { renderCart(cart); });
          } else {
            renderCart(cart);
          }
        })
        .catch(function(error) {
          console.error('Error loading cart:', error);
          cartLoading.classList.remove('active');
        });
    }

    // Render cart items
    function renderCart(cart) {
      if (cart.item_count === 0) {
        if (cartItems) cartItems.innerHTML = '';
        if (cartItems) cartItems.classList.remove('active');
        cartEmpty.classList.add('active');
        cartFooter.style.display = 'none';
        return;
      }

      cartEmpty.classList.remove('active');
      cartFooter.style.display = 'block';

      var itemsHtml = cart.items.map(function(item) {
        var variantHtml = item.variant_title !== 'Default Title' ? '<div class="cart-item-variant">' + item.variant_title + '</div>' : '';
        return '<div class="cart-item" data-cart-item="' + item.key + '"><div class="cart-item-image"><img src="' + item.image + '" alt="' + item.product_title + '" loading="lazy"></div><div class="cart-item-details"><h4 class="cart-item-title"><a href="' + item.url + '">' + item.product_title + '</a></h4>' + variantHtml + '<div class="cart-item-price">' + formatMoney(item.line_price) + '</div><div class="cart-item-actions"><div class="cart-item-quantity"><button type="button" data-cart-decrease="' + item.key + '" aria-label="Decrease quantity">-</button><span class="cart-item-quantity__value" data-cart-quantity-value="' + item.key + '" aria-label="Quantity">' + (Number(item.quantity) || 1) + '</span><button type="button" data-cart-increase="' + item.key + '" aria-label="Increase quantity">+</button></div><button type="button" class="cart-item-remove" data-cart-remove="' + item.key + '" aria-label="Remove item">Remove</button></div></div></div>';
      }).join('');
      cartItems.innerHTML = itemsHtml;

      cartItems.classList.add('active');

      // Update totals
      if (cartSubtotal) {
        cartSubtotal.textContent = formatMoney(cart.total_price);
      }
      if (cartTotal) {
        cartTotal.textContent = formatMoney(cart.total_price);
      }

      // Attach event listeners (pass cart so decrease handler can check quantity)
      attachCartListeners(cart);
    }

    // One delegated listener for all cart item buttons (attach once at init so it always works)
    function attachCartListeners(cartData) {
      if (!cartItems || cartItems._cartDelegation) return;
      cartItems._cartDelegation = true;
      function onCartItemClick(e) {
        var inc = e.target && e.target.closest ? e.target.closest('[data-cart-increase]') : null;
        var dec = e.target && e.target.closest ? e.target.closest('[data-cart-decrease]') : null;
        var rem = e.target && e.target.closest ? e.target.closest('[data-cart-remove]') : null;
        if (inc) {
          e.preventDefault();
          e.stopPropagation();
          var key = inc.getAttribute('data-cart-increase');
          var container = inc.closest('.cart-item-quantity');
          var valueEl = container && container.querySelector('[data-cart-quantity-value]');
          var current = valueEl ? (parseInt(valueEl.textContent, 10) || 1) : 1;
          updateCartItem(key, current + 1);
        } else if (dec) {
          e.preventDefault();
          e.stopPropagation();
          var key = dec.getAttribute('data-cart-decrease');
          var container = dec.closest('.cart-item-quantity');
          var valueEl = container && container.querySelector('[data-cart-quantity-value]');
          var current = valueEl ? (parseInt(valueEl.textContent, 10) || 1) : 1;
          if (current > 1) updateCartItem(key, current - 1);
        } else if (rem) {
          e.preventDefault();
          e.stopPropagation();
          removeCartItem(rem.getAttribute('data-cart-remove'));
        }
      }
      cartItems.addEventListener('click', onCartItemClick);
    }

    // Update cart item quantity (newQuantity = absolute quantity to set)
    function updateCartItem(key, newQuantity) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          id: key,
          quantity: Math.max(0, parseInt(newQuantity, 10) || 1)
        })
      })
      .then(function(response) { return response.json(); })
      .then(function(cart) {
        renderCart(cart);
        updateCartCount();
        document.dispatchEvent(new CustomEvent('cart:updated'));
      })
      .catch(function(error) {
        console.error('Error updating cart:', error);
      });
    }

    function removeCartItem(key) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          id: key,
          quantity: 0
        })
      })
      .then(function(response) { return response.json(); })
      .then(function(cart) {
        renderCart(cart);
        updateCartCount();
        document.dispatchEvent(new CustomEvent('cart:updated'));
      })
      .catch(function(error) {
        console.error('Error removing cart item:', error);
      });
    }

    function updateCartCount() {
      fetch('/cart.js')
        .then(function(response) { return response.json(); })
        .then(function(cart) {
          var cartCount = document.querySelector('[data-cart-count]');
          if (cartCount) {
            if (cart.item_count > 0) {
              cartCount.textContent = cart.item_count;
              cartCount.style.display = 'block';
            } else {
              cartCount.style.display = 'none';
            }
          }
        });
    }

    // Format money
    function formatMoney(cents) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD'
      }).format(cents / 100);
    }

    // Attach delegated listener once so +/- and Remove work as soon as content is rendered
    attachCartListeners();

    // Listen for open from theme.liquid inline script (handles [data-cart-toggle] click)
    document.addEventListener('open-cart-drawer', openCartDrawer);

    document.addEventListener('click', function(e) {
      var toggle = e.target.closest('[data-cart-toggle]');
      if (toggle) {
        e.preventDefault();
        e.stopPropagation();
        openCartDrawer();
      }
    });

    for (var c = 0; c < cartDrawerClose.length; c++) {
      cartDrawerClose[c].addEventListener('click', closeCartDrawer);
    }

    cartDrawer.addEventListener('click', function(e) {
      if (e.target.classList && e.target.classList.contains('cart-drawer-overlay')) {
        closeCartDrawer();
      }
    });

    if (cartCheckout) {
      cartCheckout.addEventListener('click', function() {
        window.location.href = '/checkout';
      });
    }

    document.addEventListener('cart:updated', function() {
      if (cartDrawer.classList.contains('active')) {
        loadCart();
      }
    });

      // Expose globally so theme.liquid inline script can call it (works regardless of load order)
      window.openCartDrawer = openCartDrawer;
      // If drawer was already opened by the theme stub before this script ran, load cart now
      if (cartDrawer.classList.contains('active')) {
        loadCart();
      }
    }

    // Run when DOM is ready; event delegation on document means cart button works whenever it exists
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCartDrawer);
    } else {
      initCartDrawer();
    }
  })();
{% endjavascript %}

